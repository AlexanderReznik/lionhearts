---
// src/layouts/BaseLayout.astro
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
}

const { title, description, ogImage, jsonLd } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <slot name="nav" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
