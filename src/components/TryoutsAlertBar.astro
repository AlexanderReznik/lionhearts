---
// src/components/TryoutsAlertBar.astro
// Slim homepage teaser bar, shown below the nav and above the hero. Renders
// nothing when there are no upcoming tryouts.
import type { Tryout } from '../lib/sheets';

interface Props { tryouts: Tryout[]; }
const { tryouts } = Astro.props;
---

{tryouts.length > 0 && (
  <aside class="tryouts-bar" aria-label="Tryouts announcement">
    <div class="tryouts-bar__inner container">
      <span class="tryouts-bar__lead">
        <span class="tryouts-bar__dot" aria-hidden="true"></span>
        <strong class="tryouts-bar__title">Tryouts now open</strong>
      </span>
      <span class="tryouts-bar__text">Secure your spot for the new season</span>
      <a href="/events#tryouts" class="tryouts-bar__link">See dates &amp; sign up →</a>
    </div>
  </aside>
)}

<style>
  .tryouts-bar {
    background: var(--lh-navy);
    color: var(--lh-white);
  }

  /* Dark theme: the page bg IS --lh-navy, so lift the bar to a raised navy
     (with a hairline) to keep the same stands-out-from-the-page contrast it
     has against white in light theme. */
  :global(html[data-theme="dark"]) .tryouts-bar {
    background: var(--lh-navy-raised);
    border-bottom: 1px solid var(--color-border);
  }

  .tryouts-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px 14px;
    padding: 10px var(--page-px);
    flex-wrap: wrap;
  }

  /* Dot + "Tryouts now open" stay together as one unit (line 1 when stacked). */
  .tryouts-bar__lead {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .tryouts-bar__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lh-blue);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--lh-blue) 25%, transparent);
    flex-shrink: 0;
  }

  .tryouts-bar__title {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-extrabold);
    color: var(--lh-blue);
  }

  .tryouts-bar__text {
    font-size: var(--text-note);
    font-weight: var(--weight-semibold);
  }

  .tryouts-bar__link {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--lh-blue);
    text-decoration: none;
    white-space: nowrap;
  }
  .tryouts-bar__link:hover { text-decoration: underline; }
  .tryouts-bar__link:focus-visible {
    outline: 2px solid var(--color-accent-to);
    outline-offset: 3px;
  }

  /* Narrow screens: stack into three centred lines —
     1) dot + "Tryouts now open"  2) the sentence  3) the link. */
  @media (max-width: 560px) {
    .tryouts-bar__inner {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
