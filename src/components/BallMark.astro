---
// src/components/BallMark.astro
// Brand motif — The Ball. Oversized volleyball watermark; ties a section to the sport.
// Decorative only (aria-hidden). Parent must be position:relative; overflow:hidden.
interface Props {
  position?: 'top-right' | 'bottom-right' | 'top-left' | 'bottom-left' | 'center';
  color?: string;
  opacity?: number;
  size?: string;
  class?: string;
}
const {
  position = 'bottom-right',
  color = 'var(--color-white)',
  opacity = 0.05,
  size = '480px',
  class: className = '',
} = Astro.props;
---

<div
  class:list={['ball', `ball--${position}`, className]}
  aria-hidden="true"
  style={`--ball-color:${color};--ball-opacity:${opacity};--ball-size:${size};`}
>
  <svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="6">
    <circle cx="100" cy="100" r="94" />
    <path d="M100 6 C 64 58, 60 132, 92 194" />
    <path d="M14 72 C 84 92, 150 118, 190 156" />
    <path d="M58 190 C 86 118, 80 54, 122 8" />
    <path d="M196 116 C 140 120, 78 132, 40 178" />
  </svg>
</div>

<style>
  .ball {
    position: absolute;
    width: var(--ball-size);
    max-width: 80%;
    color: var(--ball-color);
    opacity: var(--ball-opacity);
    pointer-events: none;
    z-index: 0;
  }
  .ball svg { width: 100%; height: auto; display: block; }

  .ball--top-right    { top: -12%;    right: -8%; }
  .ball--bottom-right { bottom: -12%; right: -8%; }
  .ball--top-left     { top: -12%;    left: -8%;  }
  .ball--bottom-left  { bottom: -12%; left: -8%;  }
  .ball--center       { top: 50%; left: 50%; transform: translate(-50%, -50%); }
</style>
