---
// src/components/SponsorsSection.astro
// TODO: Replace placeholder values with actual sponsor data from client
const sponsor = {
  name:        'Vinarius London',
  description: 'East London\'s independent wine merchant — curating small-production wines from 15+ countries, hosting tastings and supper clubs in Shoreditch.',
  url:         '/sponsors/vinarius',
  logo:        '/images/sponsors/vinarius.png',
};
---

<section class="sponsors" aria-labelledby="sponsors-heading">
  <h2 id="sponsors-heading" class="sponsors__eyebrow">Proudly supported by</h2>

  <div class="sponsors__title-card">
    <span class="sponsors__badge">Title Sponsor</span>
    <div class="sponsors__logo">
      {sponsor.logo
        ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} />
        : <span class="sponsors__logo-placeholder" aria-label={`${sponsor.name} logo`}></span>
      }
    </div>
    <a href={sponsor.url} class="sponsors__link">View sponsor page →</a>
  </div>
</section>

<style>
  .sponsors {
    padding: 64px var(--page-px);
    border-top: 1px solid var(--color-border);
  }

  .sponsors__eyebrow {
    text-align: center;
    color: rgba(255,255,255,0.5);
    font-size: 0.5625rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .sponsors__title-card {
    background: linear-gradient(135deg, rgba(84,164,247,0.12), rgba(84,164,247,0.06));
    border: 1px solid rgba(84,164,247,0.25);
    border-radius: 14px;
    padding: 48px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .sponsors__badge {
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent));
    color: #fff;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .sponsors__logo { width: 320px; max-width: 100%; }
  .sponsors__logo img {
    width: 100%;
    height: auto;
    filter: brightness(0) invert(1);
    opacity: 0.88;
  }

  .sponsors__logo-placeholder {
    width: 320px;
    height: 80px;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
  }

  .sponsors__link {
    color: var(--color-accent);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
  }
</style>
