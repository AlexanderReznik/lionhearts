---
// src/components/SponsorsSection.astro
import { SPONSORS } from '../data/sponsors';
---

<section class="sponsors" aria-labelledby="sponsors-heading">
  <h2 id="sponsors-heading" class="eyebrow eyebrow--center sponsors__eyebrow">Proudly supported by</h2>

  <div class="sponsors__grid">
    {SPONSORS.map(sponsor => (
      <div class="sponsors__title-card">
        <span class="sponsors__badge">{sponsor.tier}</span>
        <div class={`sponsors__chip sponsors__chip--${sponsor.slug}`}>
          {sponsor.logo
            ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} />
            : <span class="sponsors__logo-placeholder" aria-label={`${sponsor.name} logo`}></span>
          }
        </div>
        <p class="sponsors__caption">{sponsor.tagline}</p>
        <a href={sponsor.url} class="btn btn--accent sponsors__cta" target="_blank" rel="noopener noreferrer">{sponsor.cta} ↗</a>
      </div>
    ))}
  </div>
</section>

<style>
  .sponsors {
    padding: 64px var(--page-px);
    border-top: 1px solid var(--color-border);
  }

  /* recipe from .eyebrow + .eyebrow--center (centered, tickless); muted colour */
  .sponsors__eyebrow {
    --color-accent-text: var(--color-text-muted);
    margin-bottom: 28px;
  }

  /* Two equal sponsor tiles, side by side; stack on mobile. */
  .sponsors__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 3vw, 28px);
    align-items: stretch;
  }

  @media (max-width: 720px) {
    .sponsors__grid { grid-template-columns: 1fr; }
  }

  /* Site-native sponsor tile; logo sits on a white chip so its knockout
     lettering stays legible in both themes. */
  .sponsors__title-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: clamp(32px, 5vw, 56px) clamp(24px, 6vw, 64px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, 30px);
    box-shadow: 0 10px 30px rgba(5, 18, 43, 0.06);
  }

  .sponsors__badge {
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    color: #fff;
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
  }

  /* Fixed-ratio chip so both sponsor logos sit in an identically-sized white
     box; each logo is contained + centred regardless of its aspect ratio. */
  .sponsors__chip {
    background: #fff;
    border: 1px solid rgba(17, 35, 75, 0.06);
    border-radius: 12px;
    padding: clamp(20px, 3vw, 30px) clamp(24px, 4vw, 40px);
    width: min(440px, 86%);
    height: clamp(128px, 14vw, 172px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(5, 18, 43, 0.12);
  }
  .sponsors__chip img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Taste's wordmark is a wide, short lockup — trim padding so it renders at a
     size comparable to Vinarius's chunkier mark inside the same-size box. */
  .sponsors__chip--taste-catering {
    padding: clamp(14px, 2vw, 20px) clamp(20px, 3vw, 30px);
  }

  .sponsors__logo-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 29 / 10;
    background: rgba(17, 35, 75, 0.06);
    border-radius: 6px;
  }

  .sponsors__caption {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    text-align: center;
    max-width: 36ch;
  }

  .sponsors__cta { border-radius: 6px; margin-top: auto; }
</style>
