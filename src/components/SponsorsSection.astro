---
// src/components/SponsorsSection.astro
// TODO: Replace placeholder values with actual sponsor data from client
const sponsor = {
  name:        'Vinarius London',
  tagline:     'East London\'s Independent Wine Merchant',
  url:         'https://vinarius.london',
  logo:        '/brand/vinarius-logo-burgundy.svg',
};
---

<section class="sponsors" aria-labelledby="sponsors-heading">
  <h2 id="sponsors-heading" class="sponsors__eyebrow">Proudly supported by</h2>

  <div class="sponsors__title-card">
    <span class="sponsors__badge">Title Sponsor</span>
    <div class="sponsors__chip">
      {sponsor.logo
        ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} />
        : <span class="sponsors__logo-placeholder" aria-label={`${sponsor.name} logo`}></span>
      }
    </div>
    <p class="sponsors__caption">{sponsor.tagline}</p>
    <a href={sponsor.url} class="btn btn--accent sponsors__cta" target="_blank" rel="noopener noreferrer">Visit Vinarius ↗</a>
  </div>
</section>

<style>
  .sponsors {
    padding: 64px var(--page-px);
    border-top: 1px solid var(--color-border);
  }

  .sponsors__eyebrow {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  /* Site-native sponsor tile; logo sits on a white chip so its knockout
     lettering stays legible in both themes. */
  .sponsors__title-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: clamp(32px, 5vw, 56px) clamp(24px, 6vw, 64px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, 30px);
    box-shadow: 0 10px 30px rgba(5, 18, 43, 0.06);
  }

  .sponsors__badge {
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    color: #fff;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
  }

  .sponsors__chip {
    background: #fff;
    border: 1px solid rgba(17, 35, 75, 0.06);
    border-radius: 12px;
    padding: clamp(20px, 3vw, 30px) clamp(24px, 4vw, 40px);
    width: min(440px, 86%);
    box-shadow: 0 8px 24px rgba(5, 18, 43, 0.12);
  }
  .sponsors__chip img {
    width: 100%;
    height: auto;
    display: block;
  }

  .sponsors__logo-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 29 / 10;
    background: rgba(17, 35, 75, 0.06);
    border-radius: 6px;
  }

  .sponsors__caption {
    color: var(--color-text-muted);
    font-size: clamp(0.9rem, 2.4vw, 1.0rem);
    text-align: center;
    max-width: 36ch;
  }

  .sponsors__cta { border-radius: 6px; }
</style>
