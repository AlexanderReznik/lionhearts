---
// src/components/InstagramFeed.astro
// Behold.so embed — free tier: 25 posts, refreshes every 24h.
// 1. Create a free account at behold.so
// 2. Connect @lionhearts_volleyball
// 3. Create a feed and copy the feed ID
// 4. Replace REPLACE_WITH_BEHOLD_FEED_ID below

const BEHOLD_FEED_ID = 'REPLACE_WITH_BEHOLD_FEED_ID';
const hasBehold = BEHOLD_FEED_ID !== 'REPLACE_WITH_BEHOLD_FEED_ID';
---

<section class="instagram" aria-labelledby="instagram-heading">
  <div class="instagram__header">
    <div>
      <h2 class="instagram__heading" id="instagram-heading">
        Follow <a href="https://instagram.com/lionhearts_volleyball" target="_blank" rel="noopener noreferrer">
          @lionhearts_volleyball
        </a>
      </h2>
    </div>
    <a
      href="https://instagram.com/lionhearts_volleyball"
      class="instagram__view-all"
      target="_blank"
      rel="noopener noreferrer"
    >
      View on Instagram →
    </a>
  </div>

  {hasBehold ? (
    <div class="instagram__embed">
      <behold-widget feed-id={BEHOLD_FEED_ID}></behold-widget>
      <script defer src="https://w.behold.so/widget.js" type="module"></script>
    </div>
  ) : (
    <div class="instagram__placeholder">
      <div class="instagram__placeholder-grid">
        {[1,2,3,4,5,6].map(i => (
          <div class="instagram__placeholder-post">
            <span class="instagram__placeholder-num">{i}</span>
          </div>
        ))}
      </div>
      <p class="instagram__placeholder-note">
        ⚡ Set up Behold.so to show a live Instagram feed here.
        Replace <code>REPLACE_WITH_BEHOLD_FEED_ID</code> in <code>InstagramFeed.astro</code>.
      </p>
    </div>
  )}
</section>

<style>
  .instagram {
    padding: 64px var(--page-px);
    border-top: 1px solid var(--color-border);
  }

  .instagram__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .instagram__heading {
    font-size: 1.375rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  .instagram__heading a {
    color: var(--color-accent-to);
    text-decoration: none;
  }

  .instagram__heading a:hover { text-decoration: underline; }

  .instagram__view-all {
    color: rgba(255,255,255,0.35);
    font-size: 0.6875rem;
    font-weight: 600;
    text-decoration: none;
  }

  .instagram__view-all:hover { color: rgba(255,255,255,0.7); }

  .instagram__placeholder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
  }

  .instagram__placeholder-post {
    aspect-ratio: 1;
    background: linear-gradient(160deg, var(--color-surface), var(--color-surface-2));
    border-radius: 6px;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .instagram__placeholder-num {
    color: rgba(255,255,255,0.1);
    font-size: 2rem;
    font-weight: 900;
  }

  .instagram__placeholder-note {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.25);
    padding: 12px 16px;
    background: rgba(0,80,220,0.07);
    border: 1px solid rgba(0,100,220,0.15);
    border-radius: 8px;
  }

  .instagram__placeholder-note code {
    background: rgba(255,255,255,0.06);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.7rem;
  }

  @media (max-width: 640px) {
    .instagram__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
