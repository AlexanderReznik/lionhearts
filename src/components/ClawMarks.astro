---
// src/components/ClawMarks.astro
// Brand motif — Claw Marks (Graphic Elements).
//   variant="slash" — #2: tapered slivers (blunt end → sharp point). Sharp / forward-moving.
//   variant="bar"   — #1: thick rounded bars. Strong / bold / heritage.
// Both fade with a length-wise gradient: SOLID at the blunt/start end → transparent at the tip.
// Decorative only (aria-hidden). Parent must be position:relative; overflow:hidden.
interface Props {
  variant?: 'slash' | 'bar';
  position?: 'top-right' | 'bottom-right' | 'top-left' | 'bottom-left';
  color?: string;
  opacity?: number;
  size?: string;
  angle?: number; // rotation in degrees; 0 = marks run straight down (solid at top)
  class?: string;
}
const {
  variant = 'slash',
  position = 'top-right',
  color = 'var(--color-accent)',
  opacity = 0.6,
  size = '320px',
  angle = 0,
  class: className = '',
} = Astro.props;

const gid = 'claw-' + Math.random().toString(36).slice(2, 9);
const cols = [80, 130, 180]; // x-centres of the three marks
---

<div
  class:list={['claw', `claw--${position}`, className]}
  aria-hidden="true"
  style={`--claw-color:${color};--claw-opacity:${opacity};--claw-size:${size};`}
>
  <svg viewBox="0 0 260 260" preserveAspectRatio="xMidYMid meet">
    <defs>
      <linearGradient id={gid} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="currentColor" stop-opacity="1" />
        <stop offset="65%"  stop-color="currentColor" stop-opacity="0.45" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </linearGradient>
    </defs>
    <g transform={`rotate(${angle} 130 130)`} fill={`url(#${gid})`}>
      {variant === 'slash'
        ? cols.map(cx => (
            <path d={`M${cx - 9} 0 Q ${cx - 5} 128 ${cx} 250 Q ${cx + 5} 128 ${cx + 9} 0 Z`} />
          ))
        : cols.map(cx => (
            <rect x={cx - 14} y="0" width="28" height="248" rx="14" />
          ))
      }
    </g>
  </svg>
</div>

<style>
  .claw {
    position: absolute;
    width: var(--claw-size);
    max-width: 60%;
    color: var(--claw-color);
    opacity: var(--claw-opacity);
    pointer-events: none;
    z-index: 0;
  }
  .claw svg { width: 100%; height: auto; display: block; }

  .claw--top-right    { top: 0;    right: 0; }
  .claw--bottom-right { bottom: 0; right: 0; }
  .claw--top-left     { top: 0;    left: 0;  }
  .claw--bottom-left  { bottom: 0; left: 0;  }
</style>
