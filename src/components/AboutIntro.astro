---
// src/components/AboutIntro.astro
const stats = [
  { value: '9×',    label: 'LVA Champions' },
  { value: '9',     label: 'Teams' },
  { value: '200+',  label: 'Members' },
  { value: '1998',  label: 'Founded' },
];
---

<section class="about-intro">
  <p class="about-intro__numeral" aria-hidden="true">01</p>
  <div class="about-intro__inner container">

    <div class="about-intro__text">
      <p class="eyebrow">Est. 1998 · Shoreditch</p>
      <h2 class="about-intro__headline">
        The heartbeat<br />of <em>East London</em><br />volleyball.
      </h2>
      <p class="about-intro__body">
        Rooted in Shoreditch since 1998, Lionhearts has grown into one of London's most celebrated
        volleyball clubs — with 9 teams and a community of players from every corner of the world.
      </p>
      <a href="/about" class="about-intro__link">Our full story →</a>
    </div>

    <div class="about-intro__cards">
      <!-- Shoreditch location card -->
      <div class="about-intro__location-card">
        <div class="about-intro__pin" aria-hidden="true">📍</div>
        <div>
          <h3>Shoreditch, <span class="about-intro__postcode">E2</span></h3>
          <p>Mulberry Academy · East London<br />No other club owns this postcode.</p>
        </div>
      </div>

      <!-- By the numbers -->
      <div class="about-intro__numbers" aria-label="Club by the numbers">
        {stats.map(s => (
          <div class="about-intro__stat">
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .about-intro {
    background: var(--color-bg);
    padding: var(--space-xl) var(--page-px);
    position: relative;
    overflow: hidden;
  }

  .about-intro__numeral {
    position: absolute;
    top: -32px;
    left: 4vw;
    font-size: var(--text-watermark);
    font-weight: var(--weight-black);
    color: rgba(84, 164, 247, 0.06);
    line-height: var(--leading-none);
    pointer-events: none;
    user-select: none;
    letter-spacing: var(--tracking-watermark);
  }

  .about-intro__inner {
    position: relative;
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .about-intro__text { flex: 1; }

  .about-intro__headline {
    font-size: var(--text-sub);
    font-weight: var(--weight-black);
    line-height: var(--leading-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    margin-bottom: 18px;
  }

  .about-intro__headline em { color: var(--color-accent-text); font-style: normal; }

  .about-intro__body {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    margin-bottom: 24px;
  }

  .about-intro__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent-text);
    font-size: var(--text-note);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
  }

  .about-intro__link:hover { text-decoration: underline; }

  .about-intro__cards {
    width: 360px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .about-intro__location-card {
    background: linear-gradient(135deg, rgba(84,164,247,0.15), rgba(84,164,247,0.07));
    border: 1px solid var(--color-border-blue);
    border-radius: 12px;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .about-intro__pin {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--color-accent-from), var(--color-accent-to));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lead);
  }

  .about-intro__location-card h3 { font-size: var(--text-body); font-weight: var(--weight-extrabold); margin-bottom: 2px; }
  .about-intro__location-card p { font-size: var(--text-note); color: var(--color-text-muted); line-height: var(--leading-normal); }
  .about-intro__postcode { color: var(--color-accent-text); font-weight: var(--weight-bold); }

  /* ── By the numbers ── */
  .about-intro__numbers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .about-intro__stat {
    background: var(--color-surface);
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .about-intro__stat strong {
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    color: var(--color-text);
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-display);
  }

  .about-intro__stat span {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .about-intro {
      padding: var(--space-lg) var(--page-px);
    }

    .about-intro__inner {
      flex-direction: column;
      gap: 32px;
    }

    .about-intro__cards {
      width: 100%;
    }
  }
</style>
