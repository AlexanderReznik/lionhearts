---
// src/components/Footer.astro
import BrandLogo from './BrandLogo.astro';
import Icon from './Icon.astro';
const year = new Date().getFullYear();

import { INSTAGRAM_URL, INSTAGRAM_HANDLE, FACEBOOK_URL, WHATSAPP_URL, CONTACT_EMAIL } from '../data/club';

const clubLinks = [
  { label: 'About Us',          href: '/about' },
  { label: 'Meet Our Teams',    href: '/teams' },
  { label: 'Sessions',          href: '/events' },
];

const involvedLinks = [
  { label: 'Join Us',        href: '/join' },
  { label: 'Open Sessions',  href: '/events' },
  { label: 'Sponsorship',    href: '/sponsorship' },
];

const contactLinks = [
  { label: CONTACT_EMAIL,    href: `mailto:${CONTACT_EMAIL}` },
  { label: INSTAGRAM_HANDLE, href: INSTAGRAM_URL },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <div class="footer__crest">
        <BrandLogo class="footer__brandlogo" width={242} height={88} />
      </div>
      <div class="footer__follow">
        <h4 class="footer__follow-title">Follow</h4>
        <div class="footer__socials">
          <a href={INSTAGRAM_URL} class="footer__social-pill footer__social-pill--instagram" target="_blank" rel="noopener noreferrer">
            <span class="footer__social-icon"><Icon name="instagram" /></span>Instagram
          </a>
          <a href={FACEBOOK_URL} class="footer__social-pill footer__social-pill--facebook" target="_blank" rel="noopener noreferrer">
            <span class="footer__social-icon"><Icon name="facebook" /></span>Facebook
          </a>
          <a href={WHATSAPP_URL} class="footer__social-pill footer__social-pill--whatsapp" target="_blank" rel="noopener noreferrer">
            <span class="footer__social-icon"><Icon name="whatsapp" /></span>WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4>Club</h4>
        <ul role="list">
          {clubLinks.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Get Involved</h4>
        <ul role="list">
          {involvedLinks.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul role="list">
          {contactLinks.map(l => (
            <li>
              <a
                href={l.href}
                {...(l.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >{l.label}</a>
            </li>
          ))}
        </ul>
        <a
          href="https://maps.google.com/?q=Mulberry+Academy+Shoreditch+Gosset+Street+E2+6NW"
          class="footer__address"
          target="_blank"
          rel="noopener noreferrer"
        >
          <address>
            Mulberry Academy Shoreditch<br />
            Gosset Street, E2 6NW
          </address>
        </a>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <p>© {year} London Lionhearts Volleyball Club. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: 52px 0 28px;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--page-px);
    display: flex;
    align-items: flex-start;
    gap: 48px;
    margin-bottom: 40px;
  }

  /* Make wrapper transparent so logo + Follow join the inner flex row directly */
  .footer__brand { display: contents; }

  .footer__crest {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 18px;
  }

  .footer__follow { flex: 1; }

  .footer__crest :global(.brand-logo__img) { height: 124px; width: auto; }

  .footer__address {
    display: block;
    color: var(--color-text-muted);
    font-size: var(--text-note);
    line-height: var(--leading-relaxed);
    font-style: normal;
    text-decoration: none;
    margin-top: 14px;
    transition: color 0.15s;
  }

  .footer__address:hover { color: var(--color-text); }
  .footer__address address { font-style: normal; }

  .footer__socials {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .footer__social-pill {
    display: flex;
    align-items: center;
    gap: 5px;
    background: color-mix(in srgb, var(--color-text) 5%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: var(--text-eyebrow);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .footer__social-pill:hover {
    border-color: var(--color-border-blue);
    color: var(--color-text);
  }

  .footer__social-icon {
    display: inline-flex;
    /* The <Icon> svg is 1em, so font-size drives its size. */
    font-size: 14px;
    flex-shrink: 0;
    /* Site brand accent (themed), matching every other icon — not per-platform. */
    color: var(--color-accent-text);
  }

  .footer__col { flex: 1; }

  .footer__col h4,
  .footer__follow-title {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent-text);
    margin-bottom: 14px;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .footer__col a {
    color: var(--color-text-muted);
    font-size: var(--text-note);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__col a:hover { color: var(--color-text); }

  .footer__bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 22px var(--page-px) 0;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__bottom p {
    color: var(--color-text-muted);
    font-size: var(--text-note);
  }

  /* Make wrapper transparent to desktop flex layout */
  .footer__cols { display: contents; }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      gap: 32px;
    }

    .footer__cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px 32px;
    }

    /* Logo + Follow sit on one row, wrapping to stack when too narrow */
    .footer__brand {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px 32px;
    }

    .footer__crest,
    .footer__follow { flex: 0 1 auto; }

    .footer__crest :global(.brand-logo__img) { height: 72px; }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
  }
</style>
