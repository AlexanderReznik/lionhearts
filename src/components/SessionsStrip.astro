---
// src/components/SessionsStrip.astro
// Reads from the same Google Sheet as /events (single source of truth).
// Falls back to the hardcoded schedule in lib/sheets.ts if the sheet is
// unavailable. Day + time are abbreviated for the compact strip layout.
import { getSessions, abbreviateDay, abbreviateTime } from '../lib/sheets';

const { sessions: raw } = await getSessions(import.meta.env.GOOGLE_SHEET_ID);
const sessions = raw.map(s => ({
  day:   abbreviateDay(s.day),
  time:  abbreviateTime(s.time),
  level: s.level,
}));
---

<aside class="sessions-strip section--community" aria-label="Weekly open sessions">
  <div class="sessions-strip__inner container">
    <div class="sessions-strip__lead">
      <span class="sessions-strip__dot" aria-hidden="true"></span>
      <span class="sessions-strip__lead-text">
        <strong>Open sessions every week.</strong>
        <span>No Booking · No Experience Needed · Mulberry Academy, E2</span>
      </span>
    </div>

    <ul class="sessions-strip__list" role="list">
      {sessions.map(s => (
        <li class="sessions-strip__item">
          <span class="sessions-strip__when">
            <span class="sessions-strip__day">{s.day}</span>
            <span class="sessions-strip__time">{s.time.range}{s.time.meridiem && (
              <span class="sessions-strip__meridiem">{s.time.meridiem}</span>
            )}</span>
          </span>
          <span class="sessions-strip__level">{s.level}</span>
        </li>
      ))}
    </ul>

    <a href="/events" class="sessions-strip__link">Full schedule →</a>
  </div>
</aside>

<style>
  .sessions-strip {
    border-top: 1px solid color-mix(in srgb, var(--lh-navy) 18%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--lh-navy) 18%, transparent);
  }

  /* Wide screens: one distributed row — lead on the left, sessions filling
     the centre, button on the right. Narrower screens fall back to a stacked
     layout (lead + button on top, sessions below) further down. */
  .sessions-strip__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 18px var(--page-px);
    min-height: 72px;
  }

  .sessions-strip__lead {
    flex-shrink: 0;
    display: flex;
    align-items: flex-start;  /* dot + text align to the first line, not the block centre */
    gap: 12px;
  }

  .sessions-strip__dot {
    width: 8px;
    height: 8px;
    margin-top: 6px;          /* centre the dot on the heading's first line */
    border-radius: 50%;
    background: var(--lh-green);
    box-shadow: 0 0 0 4px rgba(118, 205, 84, 0.18);
    flex-shrink: 0;
  }

  .sessions-strip__lead-text {
    display: flex;
    flex-direction: column;
    line-height: var(--leading-snug);
  }

  .sessions-strip__lead-text strong {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-body);
    color: var(--lh-navy);
  }

  .sessions-strip__lead-text span {
    font-size: var(--text-note);
    color: var(--color-text-muted);
  }

  .sessions-strip__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;          /* items flow onto more rows for any session count */
    gap: 8px 0;
    flex: 1;                  /* fill the central space */
    min-width: 0;
    justify-content: center;  /* sessions sit in the middle of the row */
    margin: 0;
    padding: 0;
  }

  .sessions-strip__item {
    display: flex;
    flex-direction: column;   /* day + time on top, level underneath */
    align-items: flex-start;
    gap: 2px;
    padding: 0 20px;
    border-left: 1px solid rgba(17, 35, 75, 0.15);
    white-space: nowrap;
  }

  .sessions-strip__item:first-child { border-left: none; padding-left: 0; }

  .sessions-strip__when {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .sessions-strip__day {
    font-size: var(--text-body);          /* match the time size */
    font-weight: var(--weight-semibold);              /* lighter than the 900 time, to differentiate */
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--lh-navy);
    white-space: nowrap;
  }

  .sessions-strip__time {
    font-size: var(--text-body);
    font-weight: var(--weight-black);
    color: var(--lh-navy);
    letter-spacing: var(--tracking-body);
    white-space: nowrap;
  }

  /* Quiet unit label: smaller + lighter + muted, so the numbers stay the headline. */
  .sessions-strip__meridiem {
    margin-left: 0.2em;
    font-size: var(--text-note);
    font-weight: var(--weight-semibold);
    opacity: 0.6;
  }

  .sessions-strip__level {
    font-size: var(--text-eyebrow);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-body);
    white-space: nowrap;
  }

  .sessions-strip__link {
    flex-shrink: 0;
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--lh-navy);
    text-decoration: none;
    white-space: nowrap;
    padding: 8px 14px;
    border: 1px solid color-mix(in srgb, var(--lh-navy) 22%, transparent);
    border-radius: 6px;
  }

  .sessions-strip__link:hover { text-decoration: underline; }

  /* Below the content max-width (1120px) the one-row layout can't fit, so
     stack it — lead + button on top, sessions (with level) left-aligned below. */
  @media (max-width: 1120px) {
    .sessions-strip__inner {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "lead link"
        "list list";
      column-gap: 32px;
      row-gap: 14px;
    }

    .sessions-strip__lead { grid-area: lead; min-width: 0; }
    .sessions-strip__list { grid-area: list; justify-content: flex-start; }
    .sessions-strip__link { grid-area: link; justify-self: end; }
  }

  @media (max-width: 560px) {
    .sessions-strip__list {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    .sessions-strip__item {
      flex-direction: row;     /* full-width row again: day+time left, level right */
      align-items: baseline;
      padding: 8px 0;
      border-left: none;
      border-top: 1px solid rgba(17, 35, 75, 0.12);
      gap: 10px;
    }

    .sessions-strip__item:first-child {
      border-top: none;
      padding-top: 0;
    }

    .sessions-strip__day { min-width: 32px; }
    .sessions-strip__time { flex: 0 0 auto; }
    .sessions-strip__level { margin-left: auto; text-align: right; }
  }
</style>
