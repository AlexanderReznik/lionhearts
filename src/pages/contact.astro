---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const contactMethods = [
  {
    icon: '✉️',
    tag: 'Email',
    title: 'Drop Us a Message',
    body: 'For general enquiries, sponsorship, or anything else.',
    link: { label: 'allanzelion@gmail.com', href: 'mailto:allanzelion@gmail.com' },
  },
  {
    icon: '📷',
    tag: 'Fastest Response',
    title: 'Instagram DM',
    body: 'We check our DMs regularly — fastest way to get a reply from us.',
    link: { label: '@lionhearts_volleyball', href: 'https://instagram.com/lionhearts_volleyball' },
    featured: true,
  },
  {
    icon: '🏐',
    tag: 'In Person',
    title: 'Come to a Session',
    body: 'The best way to meet us — join an open session and say hello on court.',
    link: { label: 'View Schedule →', href: '/events' },
  },
];

const BRAND_ICONS: Record<string, string> = {
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z',
  facebook: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  youtube: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
};

const socials = [
  {
    brand: 'instagram',
    name: 'Instagram',
    handle: '@lionhearts_volleyball · 2,104 followers',
    href: 'https://instagram.com/lionhearts_volleyball',
  },
  {
    brand: 'facebook',
    name: 'Facebook',
    handle: 'londonlionhearts.volleyball',
    href: 'https://facebook.com/lionheartsvolleyball',
  },
  {
    brand: 'youtube',
    name: 'YouTube',
    handle: '@londonlionheartsvolleyball5826',
    href: 'https://youtube.com/@londonlionheartsvolleyball5826',
  },
];

const MAPS_URL = 'https://maps.google.com/?q=Mulberry+Academy+Shoreditch+Gosset+Street+E2+6NW';
---

<BaseLayout
  title="Contact"
  description="Get in touch with London Lionhearts Volleyball Club. Email, Instagram DM, or come to an open session at Mulberry Academy, Gosset Street, Shoreditch E2 6NW."
>
  <div class="page-hero">
    <p class="page-hero__eyebrow">Get in Touch</p>
    <h1 class="page-hero__title">We'd Love<br />to <em>Hear</em> From You</h1>
    <p class="page-hero__sub">Questions, sponsorship enquiries, media requests — we're easy to reach.</p>
  </div>

  <div class="page-content">

    <!-- Contact method cards -->
    <div class="contact-cards">
      {contactMethods.map(c => (
        <div class:list={['contact-card', { 'contact-card--featured': c.featured }]}>
          <div class="contact-card__icon" aria-hidden="true">{c.icon}</div>
          <div class="contact-card__text">
            <span class="contact-card__tag">{c.tag}</span>
            <h3 class="contact-card__title">{c.title}</h3>
            <a
              href={c.link.href}
              class="contact-card__link"
              {...(c.link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >{c.link.label}</a>
          </div>
        </div>
      ))}
    </div>

    <!-- Location block -->
    <div class="location-block">
      <div class="location-info">
        <h2 class="location-info__headline">Find <em>Us</em></h2>
        <address class="location-info__address">
          Mulberry Academy Shoreditch<br />
          Gosset Street<br />
          London, E2 6NW
        </address>
        <a href={MAPS_URL} class="location-info__directions" target="_blank" rel="noopener noreferrer">
          Open in Google Maps ↗
        </a>
      </div>

      <div class="location-map">
        <iframe
          src="https://maps.google.com/maps?q=Mulberry+Academy+Shoreditch+Gosset+Street+London+E2+6NW&output=embed&z=16"
          title="Mulberry Academy Shoreditch on Google Maps"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="location-map__iframe"
        ></iframe>
      </div>
    </div>

    <!-- Social row -->
    <h2 class="eyebrow section-eyebrow">Follow Us</h2>
    <div class="social-row">
      {socials.map(s => (
        <a href={s.href} class={`social-card social-card--${s.brand}`} target="_blank" rel="noopener noreferrer">
          <span class="social-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d={BRAND_ICONS[s.brand]} /></svg>
          </span>
          <div>
            <h3 class="social-card__name">{s.name}</h3>
            <p class="social-card__handle">{s.handle}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .section-eyebrow { margin-bottom: 1rem; }
  .section-eyebrow--tight { margin-bottom: 0.75rem; }

  /* ── Contact cards ── */
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }


  .contact-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: border-color 0.2s;
  }

  .contact-card:hover { border-color: rgba(0,120,255,0.3); }

  .contact-card__link:focus-visible,
  .social-card:focus-visible,
  .location-map__btn:focus-visible {
    outline: 2px solid var(--color-accent-to);
    outline-offset: 3px;
  }

  .contact-card--featured {
    background: linear-gradient(135deg, rgba(0,60,180,0.1), rgba(0,120,255,0.05));
    border-color: var(--color-border-blue);
  }

  .contact-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-accent-from), var(--color-accent-to));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .contact-card__text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .contact-card__tag {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent-to);
  }

  .contact-card__title { font-size: 0.875rem; font-weight: 700; }

  .contact-card__link {
    color: var(--color-highlight-1);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    word-break: break-all;
  }

  .contact-card__link:hover { text-decoration: underline; }

  /* ── Location block ── */
  .location-block {
    background: linear-gradient(160deg, #070f22, #0a1628);
    border: 1px solid rgba(0,100,220,0.15);
    border-radius: 16px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    margin-bottom: 32px;
  }

  .location-info {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: center;
  }

  .location-info__headline {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    margin-bottom: 0;
  }

  .location-info__headline em { color: var(--color-accent-to); font-style: normal; }

  .location-info__address {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.8;
    font-style: normal;
  }

  .location-info__directions {
    display: inline-flex;
    align-items: center;
    color: var(--color-accent-to);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    margin-top: 4px;
  }

  .location-info__directions:hover { text-decoration: underline; }

  /* Map area */
  .location-map {
    overflow: hidden;
    min-height: 280px;
  }

  .location-map__iframe {
    width: 100%;
    height: 100%;
    min-height: 280px;
    border: 0;
    display: block;
  }

  /* ── Social row ── */
  .social-row {
    display: flex;
    gap: 12px;
  }

  .social-card {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .social-card:hover { border-color: rgba(0,120,255,0.3); }

  .social-card__icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: rgba(255,255,255,0.7);
  }

  .social-card--instagram .social-card__icon { background: rgba(225,48,108,0.15); color: #e1306c; }
  .social-card--facebook  .social-card__icon { background: rgba(24,119,242,0.15); color: #4a9ef5; }
  .social-card--youtube   .social-card__icon { background: rgba(255,0,0,0.15);    color: #ff4444; }
  .social-card__name { font-size: 0.8125rem; font-weight: 700; margin-bottom: 2px; }
  .social-card__handle { font-size: 0.6875rem; color: rgba(255,255,255,0.55); }

  @media (max-width: 920px) {
    .contact-cards { grid-template-columns: repeat(2, 1fr); }
    .location-block { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .contact-cards { grid-template-columns: 1fr; }
    .location-block { grid-template-columns: 1fr; }
    .location-info { padding: 24px; }
    .location-map { min-height: 200px; }
    .location-map__iframe { min-height: 200px; }
    .social-row { flex-direction: column; }
  }
</style>
