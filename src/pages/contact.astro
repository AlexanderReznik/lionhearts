---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon, { type IconName } from '../components/Icon.astro';
import { INSTAGRAM_URL, INSTAGRAM_HANDLE, CONTACT_EMAIL } from '../data/club';

const contactMethods: {
  icon: IconName;
  tag: string;
  title: string;
  body: string;
  link: { label: string; href: string };
  featured?: boolean;
}[] = [
  {
    icon: 'email',
    tag: 'Email',
    title: 'Drop Us a Message',
    body: 'For general enquiries, sponsorship, or anything else.',
    link: { label: CONTACT_EMAIL, href: `mailto:${CONTACT_EMAIL}` },
  },
  {
    icon: 'instagram-dm',
    tag: 'Fastest Response',
    title: 'Instagram DM',
    body: 'We check our DMs regularly — fastest way to get a reply from us.',
    link: { label: INSTAGRAM_HANDLE, href: INSTAGRAM_URL },
    featured: true,
  },
  {
    icon: 'session',
    tag: 'In Person',
    title: 'Come to a Session',
    body: 'The best way to meet us — join an open session and say hello on court.',
    link: { label: 'View Schedule →', href: '/events' },
  },
];

import { SOCIAL_ICON_PATHS as BRAND_ICONS } from '../lib/socialIcons';

const socials = [
  {
    brand: 'instagram',
    name: 'Instagram',
    handle: `${INSTAGRAM_HANDLE} · 2,104 followers`,
    href: INSTAGRAM_URL,
  },
  {
    brand: 'facebook',
    name: 'Facebook',
    handle: 'londonlionhearts.volleyball',
    href: 'https://facebook.com/lionheartsvolleyball',
  },
  {
    brand: 'youtube',
    name: 'YouTube',
    handle: '@londonlionheartsvolleyball5826',
    href: 'https://youtube.com/@londonlionheartsvolleyball5826',
  },
];

const MAPS_URL = 'https://maps.google.com/?q=Mulberry+Academy+Shoreditch+Gosset+Street+E2+6NW';
---

<BaseLayout
  title="Contact"
  description="Get in touch with London Lionhearts Volleyball Club. Email, Instagram DM, or come to an open session at Mulberry Academy, Gosset Street, Shoreditch E2 6NW."
>
  <div class="page-hero">
    <p class="eyebrow page-hero__eyebrow">Get in Touch</p>
    <h1 class="page-hero__title">We'd Love<br />to <em>Hear</em> From You</h1>
    <p class="page-hero__sub">Questions, sponsorship enquiries, media requests — we're easy to reach.</p>
  </div>

  <div class="page-content">

    <!-- Contact method cards -->
    <div class="contact-cards">
      {contactMethods.map(c => (
        <div class:list={['contact-card', { 'contact-card--featured': c.featured }]}>
          <div class="contact-card__icon" aria-hidden="true"><Icon name={c.icon} /></div>
          <div class="contact-card__text">
            <span class="contact-card__tag">{c.tag}</span>
            <h3 class="contact-card__title">{c.title}</h3>
            <a
              href={c.link.href}
              class="contact-card__link"
              {...(c.link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >{c.link.label}</a>
          </div>
        </div>
      ))}
    </div>

    <!-- Location block -->
    <div class="location-block">
      <div class="location-info">
        <h2 class="location-info__headline">Find <em>Us</em></h2>
        <address class="location-info__address">
          Mulberry Academy Shoreditch<br />
          Gosset Street<br />
          London, E2 6NW
        </address>
        <a href={MAPS_URL} class="location-info__directions" target="_blank" rel="noopener noreferrer">
          Open in Google Maps ↗
        </a>
      </div>

      <div class="location-map">
        <iframe
          src="https://maps.google.com/maps?q=Mulberry+Academy+Shoreditch+Gosset+Street+London+E2+6NW&output=embed&z=16"
          title="Mulberry Academy Shoreditch on Google Maps"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="location-map__iframe"
        ></iframe>
      </div>
    </div>

    <!-- Social row -->
    <h2 class="eyebrow section-eyebrow">Follow Us</h2>
    <div class="social-row">
      {socials.map(s => (
        <a href={s.href} class={`social-card social-card--${s.brand}`} target="_blank" rel="noopener noreferrer">
          <span class="social-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d={BRAND_ICONS[s.brand]} /></svg>
          </span>
          <div>
            <h3 class="social-card__name">{s.name}</h3>
            <p class="social-card__handle">{s.handle}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Contact cards ── */
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }


  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: border-color 0.2s;
  }

  .contact-card:hover { border-color: var(--color-border-blue); }

  .contact-card__link:focus-visible,
  .social-card:focus-visible {
    outline: 2px solid var(--color-accent-to);
    outline-offset: 3px;
  }

  .contact-card--featured {
    background: linear-gradient(135deg, rgba(84,164,247,0.10), rgba(84,164,247,0.05));
    border-color: var(--color-border-blue);
  }

  .contact-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-accent-from), var(--color-accent-to));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lead);
    flex-shrink: 0;
    /* Navy-on-blue, matching the brand's .btn--accent pairing. */
    color: var(--btn-accent-text);
  }

  .contact-card__text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .contact-card__tag {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent-text);
  }

  .contact-card__title { font-size: var(--text-body); font-weight: var(--weight-bold); }

  .contact-card__link {
    color: var(--color-accent-text);
    font-size: var(--text-note);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    word-break: break-all;
  }

  .contact-card__link:hover { text-decoration: underline; }

  /* ── Location block ── */
  /* location-block is an intentional dark feature surface — navy bg, white text */
  .location-block {
    background: linear-gradient(160deg, var(--lh-navy-deep), var(--lh-navy));
    border: 1px solid rgba(84,164,247,0.15);
    border-radius: 16px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    margin-bottom: 32px;
  }

  /* Dark theme: navy panel sits on the navy page, so strengthen the brand
     light-blue (#54A4F7) hairline so it still reads as a distinct panel. */
  :global([data-theme="dark"]) .location-block {
    border-color: var(--color-border-blue);
  }

  .location-info {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: center;
    color: #fff; /* scoped override: dark panel needs white text */
    --color-accent-text: var(--lh-blue);
  }

  .location-info__headline {
    font-size: var(--text-xl);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    margin-bottom: 0;
    color: #fff;
  }

  .location-info__headline em { color: var(--color-accent-text); font-style: normal; }

  .location-info__address {
    color: rgba(255,255,255,0.75);
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    font-style: normal;
  }

  .location-info__directions {
    display: inline-flex;
    align-items: center;
    color: var(--color-accent-text);
    font-size: var(--text-note);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-body);
    text-decoration: none;
    margin-top: 4px;
  }

  .location-info__directions:hover { text-decoration: underline; }

  /* Map area */
  .location-map {
    overflow: hidden;
    min-height: 280px;
  }

  .location-map__iframe {
    width: 100%;
    height: 100%;
    min-height: 280px;
    border: 0;
    display: block;
  }

  /* ── Social row ── */
  .social-row {
    display: flex;
    gap: 12px;
  }

  .social-card {
    flex: 1;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .social-card:hover { border-color: var(--color-border-blue); }

  .social-card__icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .social-card--instagram .social-card__icon { background: rgba(225,48,108,0.12); color: #e1306c; }
  .social-card--facebook  .social-card__icon { background: rgba(24,119,242,0.12); color: #1877f2; }
  .social-card--youtube   .social-card__icon { background: rgba(255,0,0,0.10);    color: #cc0000; }
  .social-card__name { font-size: var(--text-body-sm); font-weight: var(--weight-bold); margin-bottom: 2px; }
  .social-card__handle { font-size: var(--text-note); color: var(--color-text-muted); }

  @media (max-width: 920px) {
    .contact-cards { grid-template-columns: repeat(2, 1fr); }
    .location-block { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .contact-cards { grid-template-columns: 1fr; }
    .location-block { grid-template-columns: 1fr; }
    .location-info { padding: 24px; }
    .location-map { min-height: 200px; }
    .location-map__iframe { min-height: 200px; }
    .social-row { flex-direction: column; }
  }
</style>
