---
// src/pages/sponsorship.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Replace with actual sponsor data supplied by client
const sponsor = {
  name:        'Vinarius London',
  description: 'East London\'s independent wine merchant — curating small-production wines from 15+ countries, hosting tastings and supper clubs in Shoreditch.',
  url:         'https://vinarius.london',
  logo:        '/brand/vinarius-logo-burgundy.svg',
};

const perks = [
  { icon: '📱', title: 'Social Media Exposure',   body: 'Featured across our Instagram, Facebook, and YouTube — reaching 2,000+ engaged followers and growing.' },
  { icon: '🌐', title: 'Website Presence',         body: 'Logo and profile on the Sponsorship page, linked from our homepage. Permanent backlink.' },
  { icon: '👕', title: 'Kit Branding',             body: 'Your logo on team kit — visible at every match, training session, and event throughout the season.' },
  { icon: '🎉', title: 'Event Presence',           body: 'Banners and branding at club events, tournaments, and open sessions at Mulberry Academy.' },
  { icon: '🏆', title: 'Champion Association',     body: 'Align your brand with 9× LVA Champions and an NVL Super League club — elite sport, East London.' },
  { icon: '🤝', title: 'Community Reach',          body: 'Connect directly with an international community of 200+ players and their networks in Shoreditch, E2.' },
];
---

<BaseLayout
  title="Sponsorship"
  description="Partner with London Lionhearts Volleyball Club — 9× LVA Champions, NVL Super League, 200+ members in Shoreditch E2. Social media, kit branding, event presence and more."
>
  <div class="page-hero">
    <p class="page-hero__eyebrow">Partners & Sponsors</p>
    <h1 class="page-hero__title">Our<br /><em>Sponsors</em></h1>
    <p class="page-hero__sub">
      Proudly partnered with brands who share our belief in sport, community, and East London.
    </p>
  </div>

  <div class="page-content">

    <!-- Title sponsor -->
    <h2 class="eyebrow section-eyebrow">Title Sponsor</h2>

    <div class="sponsor-hero">
      <span class="sponsor-hero__badge">Title Sponsor</span>
      <div class="sponsor-hero__logo">
        {sponsor.logo
          ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} />
          : <span class="sponsor-hero__logo-placeholder" aria-label={`${sponsor.name} logo`}></span>
        }
      </div>
      <div class="sponsor-hero__details">
        <p class="sponsor-hero__desc">{sponsor.description}</p>
        <a href={sponsor.url} class="btn btn--accent sponsor-hero__link" target="_blank" rel="noopener noreferrer">Visit Vinarius ↗</a>
      </div>
    </div>

    <!-- Become a Sponsor CTA -->
    <div class="become-sponsor">
      <div class="become-sponsor__copy">
        <p class="become-sponsor__headline">Partner With<br />Lionhearts</p>
        <p class="become-sponsor__sub">
          Reach East London's most passionate volleyball community — 200+ members, active social
          media, and growing. Sponsorship puts your brand at the heart of Shoreditch sport.
        </p>
      </div>
      <a href="mailto:allanzelion@gmail.com?subject=Sponsorship%20Enquiry" class="btn btn--white">
        Get in Touch
      </a>
    </div>

    <!-- Perks grid -->
    <h2 class="eyebrow section-eyebrow section-eyebrow--spaced">What Sponsorship Includes</h2>
    <div class="perks-grid">
      {perks.map(p => (
        <div class="perk-card">
          <div class="perk-card__icon" aria-hidden="true">{p.icon}</div>
          <h3 class="perk-card__title">{p.title}</h3>
          <p class="perk-card__body">{p.body}</p>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Title sponsor hero — site-native panel; logo on a white chip ── */
  .sponsor-hero {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: clamp(32px, 5vw, 56px) clamp(24px, 5vw, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, 30px);
    margin-bottom: 48px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(5, 18, 43, 0.06);
  }

  .sponsor-hero__badge {
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    color: #fff;
    font-size: var(--text-micro);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
  }

  .sponsor-hero__logo {
    background: #fff;
    border: 1px solid rgba(17, 35, 75, 0.06);
    border-radius: 12px;
    padding: clamp(22px, 3vw, 32px) clamp(26px, 4vw, 44px);
    width: min(460px, 86%);
    box-shadow: 0 8px 24px rgba(5, 18, 43, 0.12);
  }
  .sponsor-hero__logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .sponsor-hero__logo-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 29 / 10;
    background: rgba(17, 35, 75, 0.06);
    border-radius: 6px;
  }

  .sponsor-hero__details { max-width: 560px; }

  .sponsor-hero__desc {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    margin-bottom: 22px;
  }

  .sponsor-hero__link { border-radius: 6px; }

  /* ── Become a Sponsor — intentional dark navy CTA panel ── */
  .become-sponsor {
    background: linear-gradient(135deg, var(--lh-navy-deep), var(--lh-navy));
    border-radius: 14px;
    padding: 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 48px;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
    --color-accent-text: var(--lh-blue);
  }

  /* Dark theme: navy CTA on the navy page — add a brand light-blue (#54A4F7)
     hairline so it stays a distinct panel. Light theme keeps its borderless
     navy-on-white pop. */
  :global([data-theme="dark"]) .become-sponsor {
    border: 1px solid var(--color-border-blue);
  }

  .become-sponsor::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }

  .become-sponsor__copy { position: relative; }

  .become-sponsor__headline {
    color: var(--lh-white);
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    margin-bottom: 8px;
  }

  .become-sponsor__sub {
    color: rgba(255,255,255,0.65);
    font-size: var(--text-body);
    max-width: 400px;
    line-height: var(--leading-relaxed);
  }

  /* ── Perks grid ── */
  .perks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .perks-grid { grid-template-columns: repeat(2, 1fr); }
    .become-sponsor { flex-direction: column; gap: 24px; padding: 28px; }
  }

  @media (max-width: 480px) {
    .perks-grid { grid-template-columns: 1fr; }
  }

  .perk-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    transition: border-color 0.2s;
  }

  .perk-card:hover { border-color: var(--color-border-blue); }

  .perk-card__icon { font-size: var(--text-xl); margin-bottom: 12px; }
  .perk-card__title { font-size: var(--text-body-sm); font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: var(--tracking-display); margin-bottom: 6px; }
  .perk-card__body { font-size: var(--text-note); color: var(--color-text-muted); line-height: var(--leading-relaxed); }
</style>
