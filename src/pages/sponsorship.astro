---
// src/pages/sponsorship.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon, { type IconName } from '../components/Icon.astro';
import { CONTACT_EMAIL } from '../data/club';
import { SPONSORS } from '../data/sponsors';

const perks: { icon: IconName; title: string; body: string }[] = [
  { icon: 'social-media-exposure', title: 'Social Media Exposure',   body: 'Featured across our Instagram, Facebook, and WhatsApp — reaching 2,000+ engaged followers and growing.' },
  { icon: 'website-presence',      title: 'Website Presence',         body: 'Logo and profile on the Sponsorship page, linked from our homepage. Permanent backlink.' },
  { icon: 'kit-branding',          title: 'Kit Branding',             body: 'Your logo on team kit — visible at every match, training session, and event throughout the season.' },
  { icon: 'event-presence',        title: 'Event Presence',           body: 'Banners and branding at club events, tournaments, and open sessions at Mulberry Academy.' },
  { icon: 'champion',              title: 'Champion Pedigree',        body: "Align your brand with 9× LVA Women's Champions and an NVL Super League club — elite sport, East London." },
  { icon: 'community-reach',       title: 'Community Reach',          body: 'Connect directly with an international community of 200+ players and their networks in Shoreditch, E2.' },
];
---

<BaseLayout
  title="Sponsorship"
  description="Partner with London Lionhearts Volleyball Club — 9× LVA Women's Champions, NVL Super League, 200+ members in Shoreditch E2. Social media, kit branding, event presence and more."
>
  <div class="page-hero">
    <p class="eyebrow page-hero__eyebrow">Partners & Sponsors</p>
    <h1 class="page-hero__title">Our<br /><em>Sponsors</em></h1>
    <p class="page-hero__sub">
      Proudly partnered with brands that share our love of sport, community, and East London.
    </p>
  </div>

  <div class="page-content">

    <!-- Sponsors -->
    <h2 class="eyebrow section-eyebrow">Our Sponsors</h2>

    <div class="sponsor-grid">
      {SPONSORS.map(sponsor => (
        <div class="sponsor-hero">
          <span class="sponsor-hero__badge">{sponsor.tier}</span>
          <div class={`sponsor-hero__logo sponsor-hero__logo--${sponsor.slug}`}>
            {sponsor.logo
              ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} />
              : <span class="sponsor-hero__logo-placeholder" aria-label={`${sponsor.name} logo`}></span>
            }
          </div>
          <div class="sponsor-hero__details">
            <p class="sponsor-hero__desc">{sponsor.description}</p>
            <a href={sponsor.url} class="btn btn--accent sponsor-hero__link" target="_blank" rel="noopener noreferrer">{sponsor.cta} ↗</a>
          </div>
        </div>
      ))}
    </div>

    <!-- Become a Sponsor CTA -->
    <div class="become-sponsor">
      <div class="become-sponsor__copy">
        <p class="become-sponsor__headline">Partner With<br />Lionhearts</p>
        <p class="become-sponsor__sub">
          Reach 200+ players from 25+ countries — an active, growing community.
          Sponsorship puts your brand at the heart of Shoreditch sport.
        </p>
      </div>
      <a href={`mailto:${CONTACT_EMAIL}?subject=Sponsorship%20Enquiry`} class="btn btn--white">
        Get in Touch
      </a>
    </div>

    <!-- Perks grid -->
    <h2 class="eyebrow section-eyebrow section-eyebrow--spaced">What Sponsorship Includes</h2>
    <div class="perks-grid">
      {perks.map(p => (
        <div class="perk-card">
          <div class="perk-card__icon" aria-hidden="true"><Icon name={p.icon} /></div>
          <h3 class="perk-card__title">{p.title}</h3>
          <p class="perk-card__body">{p.body}</p>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Sponsors — two equal tiles side by side; stack on mobile ── */
  .sponsor-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 3vw, 28px);
    align-items: stretch;
    margin-bottom: 48px;
  }

  @media (max-width: 720px) {
    .sponsor-grid { grid-template-columns: 1fr; }
  }

  /* Site-native sponsor panel; logo on a white chip ── */
  .sponsor-hero {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: clamp(32px, 5vw, 56px) clamp(24px, 5vw, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, 30px);
    text-align: center;
    box-shadow: 0 10px 30px rgba(5, 18, 43, 0.06);
  }

  .sponsor-hero__badge {
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    color: #fff;
    font-size: var(--text-micro);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
  }

  /* Fixed-ratio chip so both sponsor logos sit in an identically-sized white
     box; each logo is contained + centred regardless of its aspect ratio. */
  .sponsor-hero__logo {
    background: #fff;
    border: 1px solid rgba(17, 35, 75, 0.06);
    border-radius: 12px;
    padding: clamp(22px, 3vw, 32px) clamp(26px, 4vw, 44px);
    width: min(460px, 86%);
    height: clamp(128px, 14vw, 172px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(5, 18, 43, 0.12);
  }
  .sponsor-hero__logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Taste's wordmark is a wide, short lockup — trim padding so it renders at a
     size comparable to Vinarius's chunkier mark inside the same-size box. */
  .sponsor-hero__logo--taste-catering {
    padding: clamp(14px, 2vw, 20px) clamp(20px, 3vw, 32px);
  }

  .sponsor-hero__logo-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 29 / 10;
    background: rgba(17, 35, 75, 0.06);
    border-radius: 6px;
  }

  .sponsor-hero__details { max-width: 560px; }

  .sponsor-hero__desc {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    margin-bottom: 22px;
  }

  .sponsor-hero__link { border-radius: 6px; }

  /* ── Become a Sponsor — intentional dark navy CTA panel ── */
  .become-sponsor {
    background: linear-gradient(135deg, var(--lh-navy-deep), var(--lh-navy));
    border-radius: 14px;
    padding: 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 48px;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
    --color-accent-text: var(--lh-blue);
  }

  /* Dark theme: navy CTA on the navy page — add a brand light-blue (#54A4F7)
     hairline so it stays a distinct panel. Light theme keeps its borderless
     navy-on-white pop. */
  :global([data-theme="dark"]) .become-sponsor {
    border: 1px solid var(--color-border-blue);
  }

  .become-sponsor::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }

  .become-sponsor__copy { position: relative; }

  .become-sponsor__headline {
    color: var(--lh-white);
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    margin-bottom: 8px;
  }

  .become-sponsor__sub {
    color: rgba(255,255,255,0.65);
    font-size: var(--text-body);
    max-width: 400px;
    line-height: var(--leading-relaxed);
  }

  /* ── Perks grid ── */
  .perks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .perks-grid { grid-template-columns: repeat(2, 1fr); }
    .become-sponsor { flex-direction: column; gap: 24px; padding: 28px; }
  }

  @media (max-width: 480px) {
    .perks-grid { grid-template-columns: 1fr; }
  }

  .perk-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    transition: border-color 0.2s;
  }

  .perk-card:hover { border-color: var(--color-border-blue); }

  .perk-card__icon { font-size: var(--text-xl); margin-bottom: 12px; color: var(--color-accent-text); line-height: 1; }
  .perk-card__title { font-size: var(--text-body-sm); font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: var(--tracking-display); margin-bottom: 6px; }
  .perk-card__body { font-size: var(--text-note); color: var(--color-text-muted); line-height: var(--leading-relaxed); }
</style>
