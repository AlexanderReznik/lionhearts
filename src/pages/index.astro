---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SessionsStrip from '../components/SessionsStrip.astro';
import AboutIntro from '../components/AboutIntro.astro';
import CommunitySection from '../components/CommunitySection.astro';
import ClubBridge from '../components/ClubBridge.astro';
import JoinCTA from '../components/JoinCTA.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import TryoutsAlertBar from '../components/TryoutsAlertBar.astro';
import TryoutsBand from '../components/TryoutsBand.astro';
import { getUpcomingTryouts } from '../lib/sheets';
import { INSTAGRAM_URL, FACEBOOK_URL, WHATSAPP_URL } from '../data/club';

// Hero images are processed at build time by Astro's <Picture> component,
// which generates AVIF + WebP + JPEG variants at 640/960/1280/1920/2560 widths.
// Drop your real photos into src/assets/hero/ and swap the imports below.
// See human-todo.md § 11 for size/format guidance.
import heroPlaceholder from '../assets/hero/placeholder.jpg';
import heroCats2 from '../assets/hero/cats-2025-26-2.jpg';
// import heroSuperLeague from '../assets/hero/01-super-league.jpg';
// import heroLvaPremier from '../assets/hero/02-lva-premier.jpg';
// import heroOpenSession from '../assets/hero/03-open-session.jpg';
// import heroCommunity   from '../assets/hero/04-community.jpg';

// Pre-season tryouts — fetched once and shared by both homepage promos. Empty
// array = nothing renders (no fallback).
const tryouts = await getUpcomingTryouts(import.meta.env.GOOGLE_SHEET_ID, import.meta.env.GOOGLE_TRYOUTS_GID);

const heroSlides = [
  {
    image: heroCats2, // swap to heroSuperLeague
    label: 'SUPER LEAGUE 2025/26',
    alt: 'Lionhearts players in action at the NVL Super League',
  },
  {
    image: heroPlaceholder, // swap to heroLvaPremier
    label: 'LVA PREMIER LEAGUE',
    alt: 'Lionhearts women celebrating a win',
  },
  {
    image: heroPlaceholder, // swap to heroOpenSession
    label: 'OPEN SESSIONS · SHOREDITCH E2',
    alt: 'Open session at Mulberry Academy Shoreditch',
  },
  {
    image: heroPlaceholder, // swap to heroCommunity
    label: 'TOGETHER WE ROAR',
    alt: 'Lionhearts club community',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'London Lionhearts Volleyball Club',
  url: 'https://lionhearts.vercel.app',
  logo: 'https://lionhearts.vercel.app/images/logo-lionhearts-512.png',
  sameAs: [
    INSTAGRAM_URL,
    FACEBOOK_URL,
    WHATSAPP_URL,
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gosset Street',
    addressLocality: 'London',
    postalCode: 'E2 6NW',
    addressCountry: 'GB',
  },
  sport: 'Volleyball',
  foundingDate: '1998',
  location: {
    '@type': 'Place',
    name: 'Mulberry Academy Shoreditch',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Gosset Street',
      addressLocality: 'London',
      postalCode: 'E2 6NW',
      addressCountry: 'GB',
    },
  },
};
---

<BaseLayout
  title="London Lionhearts VBC — Shoreditch, East London"
  description="East London's volleyball club — competing from the NVL Super League to your first ever session. Open sessions 3× a week at Mulberry Academy, Shoreditch E2."
  jsonLd={orgSchema}
>
  <TryoutsAlertBar tryouts={tryouts} />
  <Hero slides={heroSlides} />
  <TryoutsBand tryouts={tryouts} />
  <SessionsStrip />
  <AboutIntro />
  <ClubBridge />
  <SponsorsSection />
  <JoinCTA />
  <CommunitySection />
  <InstagramFeed />
</BaseLayout>
