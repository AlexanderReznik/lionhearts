---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SessionsStrip from '../components/SessionsStrip.astro';
import AboutIntro from '../components/AboutIntro.astro';
import CommunitySection from '../components/CommunitySection.astro';
import ClubBridge from '../components/ClubBridge.astro';
import JoinCTA from '../components/JoinCTA.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import TryoutsAlertBar from '../components/TryoutsAlertBar.astro';
import TryoutsBand from '../components/TryoutsBand.astro';
import { getUpcomingTryouts } from '../lib/sheets';
import { INSTAGRAM_URL, FACEBOOK_URL, WHATSAPP_URL, SITE_URL } from '../data/club';

// Hero images are processed at build time by Astro's <Picture> component,
// which generates AVIF + WebP + JPEG variants at 640/960/1280/1920/2560 widths.
// Drop your real photos into src/assets/hero/ and swap the imports below.
// See human-todo.md § 11 for size/format guidance.
import vinariusHug from '../assets/hero/vinarius_hug.jpg';
import vinariusCelebration from '../assets/hero/vinarius_celebration.jpg';
import vinariusSet from '../assets/hero/vinarius_set.jpg';
import martynasDig from '../assets/hero/martynas_dig.jpg';
import catsCelebration from '../assets/hero/cats_celebration.jpg';

// Pre-season tryouts — fetched once and shared by both homepage promos. Empty
// array = nothing renders (no fallback).
const tryouts = await getUpcomingTryouts(import.meta.env.GOOGLE_SHEET_ID, import.meta.env.GOOGLE_TRYOUTS_GID);

const heroSlides = [
  {
    image: vinariusCelebration,
    label: 'Photo by Nathaniel Macrae',
    alt: 'Lionhearts women celebrating a point at the NVL Super League',
  },
  {
    image: catsCelebration,
    label: 'Photo by Michal Kocián',
    alt: 'Lionhearts players in action',
  },
  {
    image: martynasDig,
    label: "Photo by Michal Kocián",
    alt: 'Lionhearts men’s player digging the ball during a match',
  },
  {
    image: vinariusHug,
    label: 'Photo by Nathaniel Macrae',
    alt: 'Lionhearts players celebrating together during a match',
  },
  {
    image: vinariusSet,
    label: 'Photo by Nathaniel Macrae',
    alt: 'Lionhearts setter rising for a set during a match',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'London Lionhearts Volleyball Club',
  url: SITE_URL,
  logo: `${SITE_URL}/images/logo-lionhearts-512.png`,
  sameAs: [
    INSTAGRAM_URL,
    FACEBOOK_URL,
    WHATSAPP_URL,
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gosset Street',
    addressLocality: 'London',
    postalCode: 'E2 6NW',
    addressCountry: 'GB',
  },
  sport: 'Volleyball',
  foundingDate: '1998',
  location: {
    '@type': 'Place',
    name: 'Mulberry Academy Shoreditch',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Gosset Street',
      addressLocality: 'London',
      postalCode: 'E2 6NW',
      addressCountry: 'GB',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 51.527392,
      longitude: -0.069586,
    },
  },
};
---

<BaseLayout
  title="London Lionhearts VBC — Shoreditch, East London"
  description="East London's volleyball club — competing from the NVL Super League to your first ever session. Open sessions 3× a week at Mulberry Academy, Shoreditch E2."
  jsonLd={orgSchema}
>
  <TryoutsAlertBar tryouts={tryouts} />
  <Hero slides={heroSlides} />
  <TryoutsBand tryouts={tryouts} />
  <SessionsStrip />
  <AboutIntro />
  <ClubBridge />
  <SponsorsSection />
  <JoinCTA />
  <CommunitySection />
  <InstagramFeed />
</BaseLayout>
