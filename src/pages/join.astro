---
// src/pages/join.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Join Us"
  description="Come play volleyball in Shoreditch, East London. Open sessions Mon, Thu & Fri at Mulberry Academy — no experience needed, no booking required. Or DM us on Instagram."
>
  <div class="page-hero">
    <p class="page-hero__eyebrow">All levels welcome</p>
    <h1 class="page-hero__title">Come <em>Play</em><br />With Us</h1>
    <p class="page-hero__sub">
      Whether you're a seasoned competitor or picking up a volleyball for the first time —
      there's a place for you at Lionhearts. Get involved however feels right.
    </p>
  </div>

  <div class="page-content">

    <!-- Three pathways -->
    <div class="pathways">

      <!-- 1: Open session -->
      <div class="pathway pathway--featured section--community">
        <p class="pathway__rec">Best way in</p>
        <div class="pathway__icon" aria-hidden="true">🏐</div>
        <h2 class="pathway__title">Come to an Open Session</h2>
        <p class="pathway__body">
          The easiest way in — just show up and play. No booking, no commitment, no experience
          needed. Meet the community and see if it's for you.
        </p>
        <a href="/events" class="btn btn--white pathway__cta">See Full Schedule</a>
      </div>

      <!-- 2: Instagram -->
      <div class="pathway">
        <div class="pathway__icon" aria-hidden="true">📷</div>
        <h2 class="pathway__title">Say Hi on Instagram</h2>
        <p class="pathway__body">
          Drop us a DM — we love hearing from new people. Ask us anything: which team might
          suit you, what level you need to be, how to get started.
        </p>
        <a
          href="https://instagram.com/lionhearts_volleyball"
          class="pathway__insta-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          📷 &nbsp;@lionhearts_volleyball
        </a>
      </div>

      <!-- 3: Form -->
      <div class="pathway">
        <div class="pathway__icon" aria-hidden="true">✉️</div>
        <h2 class="pathway__title">Tell Us About Yourself</h2>
        <p class="pathway__body">
          Want us to find the right fit for you? Fill in the short form below and we'll reach
          out to match you with the right team or session.
        </p>
        <a href="#join-form" class="btn btn--ghost pathway__form-link">Fill in the Form ↓</a>
      </div>

    </div>

    <!-- Join form -->
    <h2 class="eyebrow section-eyebrow" id="join-form">Tell us about yourself</h2>
    <p class="form-intro">Can't make a session? Fill in the short form and we'll match you to the right team or level.</p>

    <form
      class="join-form"
      method="POST"
      action="https://api.web3forms.com/submit"
    >
      <input type="hidden" name="access_key" value="f2d05eaf-a31d-4870-949c-4f5b1c7fb19d" />
      <input type="hidden" name="subject" value="New enquiry — London Lionhearts VBC" />
      <input type="hidden" name="from_name" value="Lionhearts Website" />
      <input type="hidden" name="redirect" value="https://lionheartsvolleyball.com/join-success/" />
      <input type="checkbox" name="botcheck" style="display:none" />

      <!-- Section 1: Your details -->
      <div class="join-form__section">
        <p class="join-form__section-label">Your Details</p>
        <div class="join-form__grid">
          <div class="join-form__field">
            <label for="first-name">First Name</label>
            <input id="first-name" type="text" name="first_name" placeholder="Your name" required />
          </div>
          <div class="join-form__field">
            <label for="last-name">Last Name</label>
            <input id="last-name" type="text" name="last_name" placeholder="Your surname" required />
          </div>
          <div class="join-form__field">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="join-form__field">
            <label for="phone">Phone <span class="join-form__optional">(optional)</span></label>
            <input id="phone" type="tel" name="phone" placeholder="+44..." />
          </div>
        </div>
      </div>

      <!-- Section 2: Your volleyball -->
      <div class="join-form__section">
        <p class="join-form__section-label">Your Volleyball</p>
        <div class="join-form__grid">
          <div class="join-form__field">
            <label for="position">Playing Position</label>
            <select id="position" name="position">
              <option value="not_sure">Not sure yet</option>
              <option value="setter">Setter</option>
              <option value="outside_hitter">Outside Hitter</option>
              <option value="middle_blocker">Middle Blocker</option>
              <option value="libero">Libero</option>
              <option value="opposite">Opposite</option>
            </select>
          </div>
          <div class="join-form__field">
            <label for="level">Experience Level</label>
            <select id="level" name="experience_level">
              <option value="beginner">Total Beginner</option>
              <option value="some_experience">Some Experience</option>
              <option value="intermediate">Intermediate</option>
              <option value="advanced">Advanced / Competitive</option>
            </select>
          </div>
          <div class="join-form__field join-form__field--full">
            <label for="message">Anything else you'd like us to know? <span class="join-form__optional">(optional)</span></label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell us about yourself, your volleyball background, what you're looking for..."
            ></textarea>
          </div>
        </div>
      </div>

      <div class="join-form__field join-form__field--full join-form__consent">
        <label class="join-form__consent-label">
          <input type="checkbox" name="consent" required />
          I agree that London Lionhearts VBC may contact me about my enquiry.
          Your information is handled in accordance with UK&nbsp;GDPR and will not be shared with third parties.
        </label>
      </div>

      <button type="submit" class="btn btn--primary join-form__submit">Send Enquiry →</button>
      <p class="join-form__note">
        We'll get back to you within a few days. In a rush?
        <a href="https://instagram.com/lionhearts_volleyball" target="_blank" rel="noopener noreferrer">
          DM us on Instagram
        </a>
        for a faster response.
      </p>
    </form>

  </div>
</BaseLayout>

<style>
  /* ── Pathways ── */
  .pathways {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 52px;
  }

  @media (max-width: 768px) {
    .pathways { grid-template-columns: 1fr; }
  }

  .pathway {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }

  /* featured pathway: force community bg (scoped .pathway wins over global .section--community) */
  .pathway--featured {
    background: var(--lh-blue);
    border-color: rgba(17,35,75,0.3);
  }

  /* title inherits --color-text which is navy on light bg; force white on blue card */
  .pathway--featured .pathway__title { color: var(--lh-white); }

  .pathway__rec {
    font-size: 0.4375rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
  }

  .form-intro {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.65;
    margin-top: -12px;
    margin-bottom: 28px;
    max-width: 520px;
  }

  .pathway--featured::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    pointer-events: none;
  }

  .pathway__icon { font-size: 2.25rem; }

  .pathway__title {
    font-size: 1.125rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  /* non-featured pathways are on a light surface — use dark text tokens */
  .pathway__body {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    flex: 1;
  }

  /* featured (community) pathway: body + rec in navy for AA contrast on #54a4f7 */
  .pathway--featured .pathway__body { color: var(--lh-navy); }
  .pathway--featured .pathway__rec { color: var(--lh-navy); }

  .pathway__cta { align-self: flex-start; }

  .pathway__insta-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 12px 16px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--color-bg-alt);
    margin-top: auto;
    transition: border-color 0.15s;
  }

  .pathway__insta-link:hover { border-color: var(--color-border-blue); }

  .pathway__form-link { margin-top: auto; text-align: center; width: 100%; }

  /* ── Join form ── */
  .join-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .join-form__section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px;
  }

  .join-form__section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  .join-form__section-label::before {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    flex-shrink: 0;
  }

  .join-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .join-form__field { display: flex; flex-direction: column; gap: 7px; }
  .join-form__field--full { grid-column: span 2; }

  @media (max-width: 640px) {
    .join-form__grid { grid-template-columns: 1fr; }
    .join-form__field--full { grid-column: span 1; }
  }

  .join-form__field label {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .join-form__optional { font-weight: 400; color: var(--color-text-faint); text-transform: none; letter-spacing: 0; }

  .join-form__field input,
  .join-form__field select,
  .join-form__field textarea {
    width: 100%;
    box-sizing: border-box;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--color-text);
    font-size: 0.875rem;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s;
  }

  .join-form__field input:hover,
  .join-form__field select:hover,
  .join-form__field textarea:hover {
    border-color: var(--color-border-blue);
    background: var(--color-bg-alt);
  }

  .join-form__field input:focus-visible,
  .join-form__field select:focus-visible,
  .join-form__field textarea:focus-visible {
    outline: none;
    border-color: var(--color-accent-text);
    background: rgba(84,164,247,0.06);
    box-shadow: 0 0 0 3px rgba(84,164,247,0.15);
  }

  .join-form__field textarea { resize: vertical; min-height: 100px; }

  .join-form__field select option { background: var(--color-surface); }

  .join-form__consent {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 16px 20px;
  }

  .join-form__consent-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    cursor: pointer;
  }

  .join-form__consent-label input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-accent-text);
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .join-form__submit {
    width: 100%;
    justify-content: center;
    margin-top: 8px;
    padding: 15px;
    font-size: 0.875rem;
    letter-spacing: 1px;
  }

  .join-form__note {
    color: var(--color-text-muted);
    font-size: 0.6875rem;
    line-height: 1.6;
    text-align: center;
  }

  .join-form__note a { color: var(--color-accent-text); }
</style>
