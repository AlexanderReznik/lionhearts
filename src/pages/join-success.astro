---
// src/pages/join-success.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { INSTAGRAM_URL } from '../data/club';
---

<BaseLayout
  title="Thanks!"
  description="Thanks for getting in touch with London Lionhearts Volleyball Club."
  noindex={true}
>
  <div class="success-page">
    <div class="success-page__icon" aria-hidden="true"><Icon name="session" /></div>
    <h1 class="success-page__title">Thanks for reaching out!</h1>
    <p class="success-page__body">
      We'll get back to you within a few days. In a rush?
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="success-page__link">
        DM us on Instagram
      </a>
      for a faster response.
    </p>
    <a href="/" class="btn btn--primary success-page__cta">Back to Home</a>
  </div>
</BaseLayout>

<style>
  .success-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .success-page__icon { font-size: var(--text-3xl); color: var(--color-accent-text); line-height: 1; }

  .success-page__title {
    font-size: var(--text-sub);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
  }

  .success-page__body {
    color: var(--color-text-muted);
    max-width: 400px;
    line-height: var(--leading-relaxed);
  }

  .success-page__link { color: var(--color-accent-text); }

  .success-page__cta { margin-top: 1rem; }
</style>
