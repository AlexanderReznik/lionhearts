---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'London Lionhearts Volleyball Club',
  url: 'https://lionhearts.vercel.app',
  foundingDate: '1998',
  founder: { '@type': 'Person', name: 'Alvin Spencer' },
  sport: 'Volleyball',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gosset Street',
    addressLocality: 'London',
    postalCode: 'E2 6NW',
    addressCountry: 'GB',
  },
};

// Our Values — Allan's copy (slides 40–41). `iconSvg` is an optional path to a
// future custom SVG (S42); while null we render the emoji fallback.
const valuesIntro =
  'As a friendly local club, we have social values and community as top of mind.';

const values = [
  {
    icon: '🤝',
    iconSvg: null as string | null,
    title: 'Inclusivity',
    body: 'We act as catalysts for change for a truly inclusive society by promoting safe, accessible and fair participation, and inspiring physical activity for all.',
  },
  {
    icon: '⚖️',
    iconSvg: null as string | null,
    title: 'Respect',
    body: 'We value and celebrate unique and diverse talents, experiences and perspectives. We treat our participants, partners, donors, and each other with sensitivity and respect.',
    featured: true,
  },
  {
    icon: '🤲',
    iconSvg: null as string | null,
    title: 'Collaboration',
    body: 'We work and win together, individually and collectively, as distinct and diverse individuals.',
  },
];

const mission =
  'To develop, promote growth and increase the quality of volleyball for everyone within our community. Together, we can create positive opportunities that generate sustainable societal change.';
---

<BaseLayout
  title="About Us"
  description="Founded in 1998 by Alvin Spencer, London Lionhearts Volleyball Club has been Shoreditch's home for volleyball for over 25 years. 9× LVA Champions, NVL Super League club."
  jsonLd={orgSchema}
>
  <!-- Page hero -->
  <div class="page-hero">
    <p class="eyebrow page-hero__eyebrow">London Lionhearts · Since 1998</p>
    <h1 class="page-hero__title">About <em>Us</em></h1>
    <p class="page-hero__sub">
      The story of Shoreditch's volleyball club — 25+ years of community, competition,
      and players from every corner of the world.
    </p>
  </div>

  <!-- History section -->
  <section class="about-history page-content">
    <div class="about-history__inner">
      <div class="about-history__photo" aria-label="Team photo — to be provided"></div>

      <div class="about-history__story">
        <p class="eyebrow">Est. 1998 · Shoreditch, East London</p>
        <h2 class="about-history__headline">
          The heartbeat of <em>East London</em> volleyball.
        </h2>

        <div class="about-history__chips">
          <div class="about-history__chip">
            <strong>Alvin Spencer</strong>
            <span>Founder, 1998</span>
          </div>
          <div class="about-history__chip">
            <strong>Allan Mungroo</strong>
            <span>Club Director, since 2008</span>
          </div>
        </div>

        <p>
          Founded in 1998 by Alvin Spencer, Lionhearts began as a small community club in
          Shoreditch. Over 25 years it has grown into one of East London's most celebrated
          volleyball clubs — 9× LVA Women's Premier Champions, an NVL Super League club,
          and a community that draws players from every corner of the world.
        </p>
        <p>
          Since 2008, Allan Mungroo has led the club through its most successful era, building
          not just competitive teams but a place where newcomers to London find their footing,
          expats find community, and beginners find their sport.
        </p>

        <a href="/join" class="btn btn--primary about-history__cta">
          Join the community →
        </a>
      </div>
    </div>

  </section>

  <!-- Values band — dark feature surface; copy from Allan (slides 40–41) -->
  <section class="about-values section--feature">
    <div class="about-values__inner container">
      <p class="eyebrow">Our Values</p>
      <p class="about-values__intro">{valuesIntro}</p>
      <div class="values-row">
        {values.map(v => (
          <div class:list={['value-card', { 'value-card--featured': v.featured }]}>
            <div class="value-card__icon" aria-hidden="true">
              {v.iconSvg
                ? <img class="value-card__icon-svg" src={v.iconSvg} alt="" />
                : v.icon}
            </div>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__body">{v.body}</p>
          </div>
        ))}
      </div>

      <div class="about-mission">
        <h3 class="eyebrow about-mission__eyebrow">Our Mission</h3>
        <p class="about-mission__text">{mission}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-history__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .about-history__photo {
    aspect-ratio: 4/3;
    background: linear-gradient(160deg, var(--color-surface-2), var(--color-surface));
    border-radius: 14px;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-faint);
    font-size: var(--text-note);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .about-history__headline {
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    margin-bottom: 20px;
    line-height: var(--leading-none);
  }

  .about-history__headline em { color: var(--color-accent-text); font-style: normal; }

  .about-history__chips {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .about-history__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(84,164,247,0.10);
    border: 1px solid var(--color-border-blue);
    border-radius: 6px;
    padding: 7px 14px;
  }

  .about-history__chip strong { font-size: var(--text-note); font-weight: var(--weight-bold); }
  .about-history__chip span { font-size: var(--text-eyebrow); color: var(--color-text-muted); }

  .about-history__cta { margin-top: 1.5rem; }

  .about-history__story p {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    margin-bottom: 12px;
  }

  /* Values — dark feature band; cards are white-alpha glass on navy */
  .about-values { padding: 56px var(--page-px); }
  .about-values__inner .eyebrow { margin-bottom: 24px; }

  .values-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .value-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .value-card:hover { border-color: var(--color-border-blue); transform: translateY(-2px); }

  /* Featured ("Competitive") is the vivid accent on the dark band */
  .value-card--featured {
    background: rgba(84,164,247,0.14);
    border-color: rgba(84,164,247,0.45);
  }

  .value-card__icon { font-size: var(--text-2xl); margin-bottom: 14px; }
  .value-card__title { font-size: var(--text-body); font-weight: var(--weight-black); text-transform: uppercase; letter-spacing: var(--tracking-display); margin-bottom: 8px; }
  .value-card__body { font-size: var(--text-body-sm); color: var(--color-text-muted); line-height: var(--leading-relaxed); }

  .about-values__intro {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
    margin-bottom: 28px;
  }

  .value-card__icon-svg { width: 1.75rem; height: 1.75rem; display: block; }

  /* Label on the left, statement filling the right — uses the full band width
     instead of a narrow left-hand column. */
  .about-mission {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: grid;
    grid-template-columns: minmax(150px, 220px) 1fr;
    gap: 20px 64px;
    align-items: start;
  }
  .about-mission__eyebrow { margin-bottom: 0; }
  .about-mission__text {
    font-size: var(--text-sub);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-display);
  }

  @media (max-width: 768px) {
    .about-history__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .about-history__photo {
      aspect-ratio: 16 / 9;
    }

    .about-history__headline {
      line-height: var(--leading-display);
    }

    .values-row {
      grid-template-columns: 1fr;
    }

    .about-mission {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
