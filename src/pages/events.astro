---
// src/pages/events.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterPills from '../components/FilterPills.astro';
import { getSessions, parseSessionSchedule } from '../lib/sheets';
import { teams, VOLLEYZONE_BASE_LVA, VOLLEYZONE_BASE_NVL } from '../data/teams';
import { fetchAllFixtures } from '../lib/volleyzone';

// ── Google Sheets integration ──────────────────────────────────────────────
// Set GOOGLE_SHEET_ID in your environment or Netlify/Vercel env vars.
// The sheet must be published (File → Share → Publish to web → CSV).
// Columns: day, time, level, venue, price.
// See human-todo.md item 8 for the full webhook setup that triggers a
// rebuild whenever the sheet is edited.
// ─────────────────────────────────────────────────────────────────────────
const { sessions, usingFallback } = await getSessions(import.meta.env.GOOGLE_SHEET_ID);

const fixturesMap = await fetchAllFixtures();
const buildTimestamp = new Date().toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});

// Trim match objects to only the fields the client uses before embedding as
// JSON data islands. Full Volleyzone responses include set scores, referee
// names, club logos, etc. — trimming cuts the page from ~1 MB to ~20 KB.
function slimFixtures(tf: { teamName: string; matches: import('../lib/volleyzone').Match[]; error: boolean }) {
  return {
    teamName: tf.teamName,
    error: tf.error,
    matches: tf.matches
      .filter(m =>
        (m.fixtureStatus === 'result' || m.fixtureStatus === 'fixture') &&
        (m.homeTeam.includes('Lionhearts') || m.awayTeam.includes('Lionhearts'))
      )
      .map(({ fixtureDate, fixtureStatus, homeTeam, awayTeam, homeScore, awayScore, homeResult, awayResult, venue }) =>
        ({ fixtureDate, fixtureStatus, homeTeam, awayTeam, homeScore, awayScore, homeResult, awayResult, venue })
      ),
  };
}

// ── Volleyzone URL builder ─────────────────────────────────────────────────
// NOTE: The ?team= parameter format must be verified by visiting Volleyzone,
// selecting a team, and inspecting the resulting URL. Update volleyzoneSlug
// values in src/data/teams.ts after verification.
function volleyzoneUrl(slug?: string, segment?: 'lva' | 'nvl'): string {
  const base = segment === 'nvl' ? VOLLEYZONE_BASE_NVL : VOLLEYZONE_BASE_LVA;
  if (!slug) return base;
  return `${base}?team=${encodeURIComponent(slug)}`;
}

// ── JSON-LD: Recurring events with Schedule type ───────────────────────────
const VENUE = {
  '@type': 'Place',
  name: 'Mulberry Academy Shoreditch',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gosset Street',
    addressLocality: 'London',
    postalCode: 'E2 6NW',
    addressCountry: 'GB',
  },
};

const ORGANIZER = {
  '@type': 'SportsOrganization',
  name: 'London Lionhearts Volleyball Club',
  url: 'https://lionhearts.vercel.app',
};

// Derived from the live session data (single source of truth) so the
// structured data can never drift from the schedule shown on the page.
// Sessions whose day/time can't be parsed are skipped rather than emitted
// as invalid Events.
const sessionSchemas = sessions.flatMap(s => {
  const schedule = parseSessionSchedule(s);
  if (!schedule) return [];
  return [{
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: `London Lionhearts — Open Training (${s.level})`,
    description: `Open volleyball session at ${s.venue} — ${s.level}. No booking required.`,
    location: VENUE,
    organizer: ORGANIZER,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    eventSchedule: {
      '@type': 'Schedule',
      byDay: [schedule.byDay],
      startTime: schedule.startTime,
      endTime: schedule.endTime,
      repeatFrequency: 'P1W',
      scheduleTimezone: 'Europe/London',
    },
  }];
});

const teamSections = [
  { label: "Women's Teams", section: 'womens', spaced: false, teams: teams.filter(t => t.gender === "Women's") },
  { label: "Men's Teams",   section: 'mens',   spaced: true,  teams: teams.filter(t => t.gender === "Men's") },
];
---

<BaseLayout
  title="Sessions & Fixtures"
  description="Open volleyball sessions Mon, Thu & Fri at Mulberry Academy, Shoreditch E2. Plus league fixtures for all 9 Lionhearts teams — NVL Super League and LVA."
  jsonLd={sessionSchemas}
>
  <!-- Page hero -->
  <div class="page-hero">
    <p class="page-hero__eyebrow">Mulberry Academy · Shoreditch E2</p>
    <h1 class="page-hero__title">Sessions &<br /><em>Fixtures</em></h1>
    <p class="page-hero__sub">
      Open sessions every week — no booking, no commitment. League fixtures and results for all 9 Lionhearts teams.
    </p>
  </div>

  <div class="page-content">

    <!-- Open Sessions -->
    <section class="sessions-box" aria-labelledby="sessions-heading">
      <h2 class="eyebrow" id="sessions-heading">Open Sessions</h2>

      {usingFallback && (
        <p class="sessions-box__notice">
          ℹ️ Schedule confirmed — check our Instagram for any last-minute changes.
        </p>
      )}

      <div class="session-cards">
        {sessions.map(s => (
          <div class="session-card section--community">
            <div class="session-card__day">{s.day}</div>
            <div class="session-card__time">{s.time}</div>
            <div class="session-card__level">{s.level}</div>
            <div class="session-card__venue">📍 {s.venue}<br />{s.price}</div>
          </div>
        ))}
        <div class="session-card session-card--venue section--community">
          <div class="session-card__venue-label">Venue</div>
          <strong>Mulberry Academy Shoreditch</strong>
          <span>Gosset Street, E2 6NW</span>
          <a
            href="https://maps.google.com/?q=Mulberry+Academy+Shoreditch"
            target="_blank"
            rel="noopener noreferrer"
            class="session-card__map-link"
          >
            Open in Maps ↗
          </a>
          <span class="session-card__transport">
            Short walk from Bethnal Green,<br />Shoreditch High Street or Hoxton
          </span>
        </div>
      </div>
    </section>

    <FilterPills statusId="filter-status" label="Filter by team type" />

    {teamSections.map(({ label, section, spaced, teams: sectionTeams }) => (
      <>
        <h2 class:list={['eyebrow section-eyebrow', { 'section-eyebrow--spaced': spaced }]} data-section={section}>{label}</h2>
        {sectionTeams.map(team => (
          <div
            class="team-fixture-section"
            data-gender={section}
            data-league={team.division.startsWith('NVL') ? 'nvl' : 'lva'}
            data-updated={buildTimestamp}
            data-volleyzone-url={volleyzoneUrl(team.volleyzoneSlug, team.volleyzoneSegment)}
          >
            <div class="team-fixture-section__header">
              <div>
                <span class="team-fixture-section__name">{team.name}</span>
                {team.badge && <span class="team-fixture-section__badge">{team.badge}</span>}
              </div>
              <div class="team-fixture-section__right">
                <span class="team-fixture-section__division">{team.division}</span>
              </div>
            </div>
            <script
              type="application/json"
              data-fixtures
              set:html={JSON.stringify(
                slimFixtures(fixturesMap[team.name] ?? { teamName: team.name, matches: [], error: true })
              ).replace(/<\//g, '<\\/')}
            />
            <div class="team-fixtures"></div>
          </div>
        ))}
      </>
    ))}

  </div>

  <script>
    import { parseScore, parseHomeAway, formatFixtureDate, formatFixtureTime } from '../lib/volleyzone';
    import type { Match, TeamFixtures } from '../lib/volleyzone';

    function esc(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderFixtures(section: HTMLElement): void {
      const island = section.querySelector<HTMLScriptElement>('script[data-fixtures]');
      const target = section.querySelector<HTMLElement>('.team-fixtures');
      if (!island || !target) return;

      const data = JSON.parse(island.textContent ?? '{}') as TeamFixtures;
      const vzUrl = section.dataset.volleyzoneUrl ?? '#';
      const updated = section.dataset.updated ?? '';

      if (data.error && data.matches.length === 0) {
        target.innerHTML = `<div class="tl-error">Fixtures unavailable — <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">view on Volleyzone →</a></div>`;
        return;
      }

      const today = new Date();
      today.setUTCHours(0, 0, 0, 0);

      const teamMatches = data.matches.filter(
        (m: Match) => m.homeTeam.includes('Lionhearts') || m.awayTeam.includes('Lionhearts')
      );

      const results = teamMatches
        .filter((m: Match) => m.fixtureStatus === 'result')
        .sort((a: Match, b: Match) => b.fixtureDate - a.fixtureDate)
        .slice(0, 3);

      const upcoming = teamMatches
        .filter((m: Match) => m.fixtureStatus === 'fixture' && m.fixtureDate * 1000 >= today.getTime())
        .sort((a: Match, b: Match) => a.fixtureDate - b.fixtureDate)
        .slice(0, 3);

      if (teamMatches.length > 0 && results.length === 0 && upcoming.length === 0) {
        target.innerHTML = `<div class="tl-error">Season complete — <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">full schedule on Volleyzone →</a></div>`;
        return;
      }

      let html = '';

      if (results.length > 0) {
        html += `<div class="tl-section-label">Recent Results</div>`;
        for (const m of results) {
          const isHome = parseHomeAway(m) === 'Home';
          const opponent = esc(isHome ? m.awayTeam : m.homeTeam);
          const { home, away } = parseScore(m.homeScore, m.awayScore);
          const resultLabel = isHome ? m.homeResult : m.awayResult;
          const w = resultLabel === 'win';
          const score = isHome ? `${home}–${away}` : `${away}–${home}`;
          const date = formatFixtureDate(m.fixtureDate);
          html += `
            <div class="tl-row">
              <span class="tl-date">${date}</span>
              <span class="tl-up-opp"><span class="tl-vs">vs </span>${opponent}</span>
              <span class="${w ? 'badge-w' : 'badge-l'}">${w ? 'W' : 'L'} ${score}</span>
            </div>`;
        }
      }

      if (upcoming.length > 0) {
        html += `<div class="tl-section-label">Upcoming Fixtures</div>`;
        upcoming.forEach((m: Match, i: number) => {
          const isHome = parseHomeAway(m) === 'Home';
          const opponent = esc(isHome ? m.awayTeam : m.homeTeam);
          const venue = esc(m.venue ?? '');
          const date = formatFixtureDate(m.fixtureDate);
          const time = formatFixtureTime(m.fixtureDate);
          const venueStr = venue ? `📍 ${venue}${time ? ` · ${time}` : ''}` : (time ?? '');
          const ha = isHome ? 'Home' : 'Away';
          const isNext = i === 0;
          html += `
            <div class="tl-row-up${isNext ? ' tl-row-up--next' : ''}">
              <span class="tl-date">${date}</span>
              <div class="tl-up-meta">
                <span class="tl-up-opp"><span class="tl-vs">vs </span>${opponent}</span>
                ${venueStr ? `<span class="tl-up-venue">${venueStr}</span>` : ''}
              </div>
              <div class="tl-right">
                ${isNext ? '<span class="next-pill">Next</span>' : ''}
                <span class="home-away">${ha}</span>
              </div>
            </div>`;
        });
      }

      html += `
        <div class="tl-footer">
          <span class="tl-updated">${updated ? `Updated ${esc(updated)}` : ''}</span>
          <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">Full schedule on Volleyzone →</a>
        </div>`;

      target.innerHTML = html;
    }

    document.querySelectorAll<HTMLElement>('.team-fixture-section').forEach(renderFixtures);
  </script>
</BaseLayout>

<script>
  const pills    = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const rows     = document.querySelectorAll<HTMLElement>('.team-fixture-section');
  const headers  = document.querySelectorAll<HTMLElement>('[data-section]');
  const status   = document.getElementById('filter-status')!

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter!;

      pills.forEach(p => {
        p.classList.remove('filter-pill--active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('filter-pill--active');
      pill.setAttribute('aria-pressed', 'true');

      rows.forEach(row => {
        const show = filter === 'all'
          || filter === row.dataset.gender
          || filter === row.dataset.league;
        row.hidden = !show;
      });

      headers.forEach(header => {
        const gender = header.dataset.section!;
        const anyVisible = Array.from(rows).some(
          r => r.dataset.gender === gender && !r.hidden
        );
        header.hidden = !anyVisible;
      });

      const visibleCount = Array.from(rows).filter(r => !r.hidden).length;
      status.textContent = `Showing ${visibleCount} team${visibleCount !== 1 ? 's' : ''}`;
    });
  });
</script>

<style>
  /* ── Sessions box ── */
  .sessions-box {
    background: linear-gradient(135deg, rgba(84,164,247,0.12), rgba(84,164,247,0.06));
    border: 1px solid var(--color-border-blue);
    border-radius: 14px;
    padding: 32px;
    margin-bottom: 36px;
  }

  .sessions-box__notice {
    font-size: 0.75rem;
    color: var(--color-accent-text);
    background: rgba(84,164,247,0.08);
    border: 1px solid rgba(84,164,247,0.25);
    border-radius: 6px;
    padding: 10px 14px;
    margin-bottom: 20px;
  }

  .session-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  /* Session cards — community tone: #54a4f7 bg (via .section--community), navy text */
  .session-card {
    border: 1px solid rgba(17,35,75,0.18);
    border-radius: 10px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .session-card__day { font-size: 0.8125rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5px; color: var(--lh-navy); }
  .session-card__time { font-size: 1.375rem; font-weight: 900; letter-spacing: -0.5px; color: var(--lh-navy); }
  .session-card__level { font-size: 0.5625rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--lh-navy); }
  .session-card__venue { font-size: 0.625rem; color: var(--lh-navy); line-height: 1.5; margin-top: 4px; }

  .session-card--venue {
    border-color: rgba(17,35,75,0.18);
    justify-content: center;
  }

  .session-card__venue-label { font-size: 0.5625rem; color: var(--lh-navy); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px; }
  .session-card--venue strong { font-size: 0.8125rem; font-weight: 700; color: var(--lh-navy); }
  .session-card--venue span { font-size: 0.6875rem; color: var(--lh-navy); }
  .session-card__map-link { color: var(--lh-navy); font-size: 0.625rem; font-weight: 700; text-decoration: none; margin-top: 8px; }
  .session-card__transport { font-size: 0.625rem; color: var(--lh-navy); margin-top: 4px; line-height: 1.5; }

  /* ── Team fixture sections ──*/
  .team-fixture-section {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .team-fixture-section__header {
    background: var(--color-bg-alt);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
    gap: 16px;
  }

  .team-fixture-section__name {
    font-size: 0.875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .team-fixture-section__badge {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent-text);
    background: rgba(84,164,247,0.15);
    padding: 3px 10px;
    border-radius: 3px;
    margin-left: 10px;
  }

  .team-fixture-section__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .team-fixture-section__division {
    font-size: 0.625rem;
    color: var(--color-text-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ── Section eyebrow headers ── */
  .section-eyebrow { margin-bottom: 1rem; }

  @media (max-width: 640px) {
    .team-fixture-section__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .team-fixture-section__right {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
  }

</style>

<style is:global>
  /* ── Fixture timeline (is:global — injected via innerHTML, scoped attr won't match) ── */
  /* Light theme: dark navy text on white/surface background */
  .team-fixtures { font-size: 0.75rem; }

  .tl-section-label {
    padding: 7px 18px 5px;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-faint);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .tl-row {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 18px;
    border-bottom: 1px solid var(--color-border);
  }

  .tl-row-up {
    display: grid;
    grid-template-columns: 62px 1fr auto;
    align-items: start;
    gap: 12px;
    padding: 10px 18px;
    border-bottom: 1px solid var(--color-border);
  }

  .tl-row-up--next {
    background: linear-gradient(90deg, rgba(84,164,247,0.10) 0%, rgba(84,164,247,0.04) 100%);
    border-left: 3px solid var(--lh-blue);
    border-bottom-color: var(--color-border-blue);
  }

  .tl-date { color: var(--color-text-faint); font-size: 0.65rem; white-space: nowrap; }
  .tl-row-up--next .tl-date { color: var(--color-accent-text); font-weight: 700; }

  .tl-vs { color: var(--color-text-faint); font-size: 0.6rem; margin-right: 4px; }

  .tl-up-meta { display: flex; flex-direction: column; gap: 3px; }
  .tl-up-opp { color: var(--color-text); }
  .tl-row-up--next .tl-up-opp { color: var(--lh-navy); font-weight: 700; }
  .tl-up-venue { color: var(--color-text-faint); font-size: 0.6rem; }
  .tl-row-up--next .tl-up-venue { color: var(--color-text-muted); }

  .tl-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }

  .next-pill {
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--lh-navy);
    background: rgba(84,164,247,0.18);
    border: 1px solid rgba(84,164,247,0.35);
    border-radius: 4px;
    padding: 2px 8px;
    white-space: nowrap;
  }

  .home-away {
    font-size: 0.55rem;
    color: var(--color-text-faint);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .tl-row-up--next .home-away { color: var(--color-text-muted); }

  /* Result badges — intentional brand colour chips; readable on light bg */
  .badge-w {
    background: rgba(118,205,84,0.15);
    color: #3a7d1e;
    border: 1px solid rgba(118,205,84,0.4);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .badge-l {
    background: rgba(196,65,40,0.10);
    /* Darkened brand red (raw --lh-red #c44128 only hits 4.41:1 on this tint);
       mirrors the .badge-w darkened-green treatment for light-theme AA. */
    color: #ad3418;
    border: 1px solid rgba(196,65,40,0.25);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
  }

  /* Dark theme: AA-legible result badges on navy rows.
     (This is an is:global style block — badges are injected via set:html and
     carry no scope attribute, so use a plain selector, not :global().) */
  html[data-theme="dark"] .badge-w { background: rgba(118,205,84,0.22); color: #8bd871; }
  html[data-theme="dark"] .badge-l { background: rgba(196,65,40,0.22); color: #e3917d; }

  .tl-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 18px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .tl-updated {
    font-size: 0.5rem;
    color: var(--color-text-faint);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tl-error {
    padding: 16px 18px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .tl-row,
    .tl-row-up {
      grid-template-columns: 56px 1fr auto;
      gap: 8px;
      padding: 10px 14px;
    }

    .tl-section-label { padding: 7px 14px 5px; }
    .tl-footer { padding: 8px 14px; flex-direction: column; align-items: flex-start; gap: 6px; }
  }
</style>
