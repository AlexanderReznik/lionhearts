---
// src/pages/events.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterPills from '../components/FilterPills.astro';
import { Image } from 'astro:assets';
import sessionPhoto from '../assets/hero/cats-2025-26-2.jpg';
import { getSessions, getJuniorSessions, parseSessionSchedule } from '../lib/sheets';
import { teams, VOLLEYZONE_BASE_LVA, VOLLEYZONE_BASE_NVL } from '../data/teams';
import { fetchAllFixtures } from '../lib/volleyzone';

// ── Google Sheets integration ──────────────────────────────────────────────
// Set GOOGLE_SHEET_ID in your environment or Netlify/Vercel env vars.
// The sheet must be published (File → Share → Publish to web → CSV).
// Columns: day, time, level, venue, price.
// See human-todo.md item 8 for the full webhook setup that triggers a
// rebuild whenever the sheet is edited.
// ─────────────────────────────────────────────────────────────────────────
const { sessions, usingFallback } = await getSessions(import.meta.env.GOOGLE_SHEET_ID);
// Tile count = sessions + the venue tile; drives the responsive grid columns.
const tileCount = sessions.length + 1;

// Junior sessions live on a separate tab of the same sheet — set
// GOOGLE_JUNIORS_GID to its gid. day + time only (no level/venue tile).
const { sessions: juniorSessions, usingFallback: juniorsFallback } =
  await getJuniorSessions(import.meta.env.GOOGLE_SHEET_ID, import.meta.env.GOOGLE_JUNIORS_GID);

const fixturesMap = await fetchAllFixtures();
const buildTimestamp = new Date().toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});

// Trim match objects to only the fields the client uses before embedding as
// JSON data islands. Full Volleyzone responses include set scores, referee
// names, club logos, etc. — trimming cuts the page from ~1 MB to ~20 KB.
function slimFixtures(tf: { teamName: string; matches: import('../lib/volleyzone').Match[]; error: boolean }) {
  return {
    teamName: tf.teamName,
    error: tf.error,
    matches: tf.matches
      .filter(m =>
        (m.fixtureStatus === 'result' || m.fixtureStatus === 'fixture') &&
        (m.homeTeam.includes('Lionhearts') || m.awayTeam.includes('Lionhearts'))
      )
      .map(({ fixtureDate, fixtureStatus, homeTeam, awayTeam, homeScore, awayScore, homeResult, awayResult, venue }) =>
        ({ fixtureDate, fixtureStatus, homeTeam, awayTeam, homeScore, awayScore, homeResult, awayResult, venue })
      ),
  };
}

// ── Volleyzone URL builder ─────────────────────────────────────────────────
// NOTE: The ?team= parameter format must be verified by visiting Volleyzone,
// selecting a team, and inspecting the resulting URL. Update volleyzoneSlug
// values in src/data/teams.ts after verification.
function volleyzoneUrl(slug?: string, segment?: 'lva' | 'nvl'): string {
  const base = segment === 'nvl' ? VOLLEYZONE_BASE_NVL : VOLLEYZONE_BASE_LVA;
  if (!slug) return base;
  return `${base}?team=${encodeURIComponent(slug)}`;
}

// ── JSON-LD: Recurring events with Schedule type ───────────────────────────
const VENUE = {
  '@type': 'Place',
  name: 'Mulberry Academy Shoreditch',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gosset Street',
    addressLocality: 'London',
    postalCode: 'E2 6NW',
    addressCountry: 'GB',
  },
};

const ORGANIZER = {
  '@type': 'SportsOrganization',
  name: 'London Lionhearts Volleyball Club',
  url: 'https://lionhearts.vercel.app',
};

// Derived from the live session data (single source of truth) so the
// structured data can never drift from the schedule shown on the page.
// Sessions whose day/time can't be parsed are skipped rather than emitted
// as invalid Events.
const sessionSchemas = sessions.flatMap(s => {
  const schedule = parseSessionSchedule(s);
  if (!schedule) return [];
  return [{
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: `London Lionhearts — Open Training (${s.level})`,
    description: `Open volleyball session at ${s.venue} — ${s.level}. No booking required.`,
    location: VENUE,
    organizer: ORGANIZER,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    eventSchedule: {
      '@type': 'Schedule',
      byDay: [schedule.byDay],
      startTime: schedule.startTime,
      endTime: schedule.endTime,
      repeatFrequency: 'P1W',
      scheduleTimezone: 'Europe/London',
    },
  }];
});

const teamSections = [
  { label: "Women's Teams", section: 'womens', spaced: false, teams: teams.filter(t => t.gender === "Women's") },
  { label: "Men's Teams",   section: 'mens',   spaced: true,  teams: teams.filter(t => t.gender === "Men's") },
];
---

<BaseLayout
  title="Sessions & Fixtures"
  description="Open volleyball sessions for adults and juniors at Mulberry Academy, Shoreditch E2. Plus league fixtures for all 9 Lionhearts teams — NVL Super League and LVA."
  jsonLd={sessionSchemas}
>
  <!-- Page hero -->
  <div class="page-hero">
    <p class="eyebrow page-hero__eyebrow">Mulberry Academy · Shoreditch E2</p>
    <h1 class="page-hero__title">Sessions &<br /><em>Fixtures</em></h1>
    <p class="page-hero__sub">
      Open sessions for adults and juniors every week — no booking, no commitment. Plus league fixtures and results for all 9 Lionhearts teams.
    </p>
  </div>

  <div class="page-content">

    <!-- Open Sessions -->
    <section class="sessions-box" aria-labelledby="sessions-heading">
      <header class="section-head">
        <h2 class="section-head__title" id="sessions-heading">Open <em>Sessions</em></h2>
        <p class="section-head__sub">Just turn up and play — every level welcome, every week.</p>
      </header>

      {usingFallback && (
        <p class="sessions-box__notice">
          ⚠️ Showing our usual weekly schedule — we couldn't load the latest times.
          Check our <a href="https://instagram.com/lionhearts_volleyball" target="_blank" rel="noopener noreferrer">Instagram</a> to confirm before heading down.
        </p>
      )}

      <div class={`session-cards session-cards--${tileCount}`}>
        {sessions.map(s => (
          <div class="session-card session-card--photo">
            <Image
              class="session-card__bg"
              src={sessionPhoto}
              alt=""
              aria-hidden="true"
              widths={[240, 360, 480]}
              sizes="(max-width: 640px) 50vw, 240px"
              loading="lazy"
            />
            <div class="session-card__content">
              <div class="session-card__day">{s.day}</div>
              <div class="session-card__time">{s.time}</div>
              <div class="session-card__level">{s.level}</div>
              <div class="session-card__venue">📍 {s.venue}<br />{s.price}</div>
            </div>
          </div>
        ))}
        <div class="session-card session-card--venue section--community">
          <div class="session-card__venue-label">Venue</div>
          <strong>Mulberry Academy Shoreditch</strong>
          <span>Gosset Street, E2 6NW</span>
          <a
            href="https://maps.google.com/?q=Mulberry+Academy+Shoreditch"
            target="_blank"
            rel="noopener noreferrer"
            class="session-card__map-link"
          >
            Open in Maps ↗
          </a>
          <span class="session-card__transport">
            Short walk from Bethnal Green,<br />Shoreditch High Street or Hoxton
          </span>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Junior Sessions -->
    <section class="sessions-box" aria-labelledby="juniors-heading">
      <header class="section-head">
        <h2 class="section-head__title" id="juniors-heading">Junior <em>Sessions</em></h2>
        <p class="section-head__sub">Volleyball for our younger players. New juniors always welcome.</p>
      </header>

      {juniorsFallback && (
        <p class="sessions-box__notice">
          ⚠️ Showing our usual junior schedule — we couldn't load the latest times.
          Check our <a href="https://instagram.com/lionhearts_volleyball" target="_blank" rel="noopener noreferrer">Instagram</a> to confirm before heading down.
        </p>
      )}

      <div class="junior-cards">
        {juniorSessions.map(s => (
          <div class="session-card session-card--photo">
            <Image
              class="session-card__bg"
              src={sessionPhoto}
              alt=""
              aria-hidden="true"
              widths={[240, 360, 480]}
              sizes="(max-width: 640px) 50vw, 240px"
              loading="lazy"
            />
            <div class="session-card__content">
              <div class="session-card__day">{s.day}</div>
              <div class="session-card__time">{s.time}</div>
              {s.level && <div class="session-card__level">{s.level}</div>}
              <div class="session-card__venue">📍 {s.venue}<br />{s.price}</div>
            </div>
          </div>
        ))}
        <div class="session-card session-card--venue section--community">
          <div class="session-card__venue-label">Venue</div>
          <strong>Mulberry Academy Shoreditch</strong>
          <span>Gosset Street, E2 6NW</span>
          <a
            href="https://maps.google.com/?q=Mulberry+Academy+Shoreditch"
            target="_blank"
            rel="noopener noreferrer"
            class="session-card__map-link"
          >
            Open in Maps ↗
          </a>
          <span class="session-card__transport">
            Short walk from Bethnal Green,<br />Shoreditch High Street or Hoxton
          </span>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <header class="section-head section-head--fixtures">
      <h2 class="section-head__title">Fixtures &amp; <em>Results</em></h2>
      <p class="section-head__sub">Follow all nine Lionhearts teams through the season — and come down to support them.</p>
    </header>

    <FilterPills statusId="filter-status" label="Filter by team type" />

    {teamSections.map(({ label, section, spaced, teams: sectionTeams }) => (
      <>
        <h3 class:list={['eyebrow section-eyebrow', { 'section-eyebrow--spaced': spaced }]} data-section={section}>{label}</h3>
        {sectionTeams.map(team => (
          <div
            class="team-fixture-section"
            data-gender={section}
            data-league={team.division.startsWith('NVL') ? 'nvl' : 'lva'}
            data-updated={buildTimestamp}
            data-volleyzone-url={volleyzoneUrl(team.volleyzoneSlug, team.volleyzoneSegment)}
          >
            <div class="team-fixture-section__header">
              <div>
                <span class="team-fixture-section__name">{team.name}</span>
                {team.badge && <span class="team-fixture-section__badge">{team.badge}</span>}
              </div>
              <div class="team-fixture-section__right">
                <span class="team-fixture-section__division">{team.division}</span>
              </div>
            </div>
            <script
              type="application/json"
              data-fixtures
              set:html={JSON.stringify(
                slimFixtures(fixturesMap[team.name] ?? { teamName: team.name, matches: [], error: true })
              ).replace(/<\//g, '<\\/')}
            />
            <div class="team-fixtures"></div>
          </div>
        ))}
      </>
    ))}

  </div>

  <script>
    import { parseScore, parseHomeAway, formatFixtureDate, formatFixtureTime } from '../lib/volleyzone';
    import type { Match, TeamFixtures } from '../lib/volleyzone';

    function esc(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderFixtures(section: HTMLElement): void {
      const island = section.querySelector<HTMLScriptElement>('script[data-fixtures]');
      const target = section.querySelector<HTMLElement>('.team-fixtures');
      if (!island || !target) return;

      const data = JSON.parse(island.textContent ?? '{}') as TeamFixtures;
      const vzUrl = section.dataset.volleyzoneUrl ?? '#';
      const updated = section.dataset.updated ?? '';

      if (data.error && data.matches.length === 0) {
        target.innerHTML = `<div class="tl-error">Fixtures unavailable — <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">view on Volleyzone →</a></div>`;
        return;
      }

      const today = new Date();
      today.setUTCHours(0, 0, 0, 0);

      const teamMatches = data.matches.filter(
        (m: Match) => m.homeTeam.includes('Lionhearts') || m.awayTeam.includes('Lionhearts')
      );

      const results = teamMatches
        .filter((m: Match) => m.fixtureStatus === 'result')
        .sort((a: Match, b: Match) => b.fixtureDate - a.fixtureDate)
        .slice(0, 3);

      const upcoming = teamMatches
        .filter((m: Match) => m.fixtureStatus === 'fixture' && m.fixtureDate * 1000 >= today.getTime())
        .sort((a: Match, b: Match) => a.fixtureDate - b.fixtureDate)
        .slice(0, 3);

      if (teamMatches.length > 0 && results.length === 0 && upcoming.length === 0) {
        target.innerHTML = `<div class="tl-error">Season complete — <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">full schedule on Volleyzone →</a></div>`;
        return;
      }

      let html = '';

      if (results.length > 0) {
        html += `<div class="tl-section-label">Recent Results</div>`;
        for (const m of results) {
          const isHome = parseHomeAway(m) === 'Home';
          const opponent = esc(isHome ? m.awayTeam : m.homeTeam);
          const { home, away } = parseScore(m.homeScore, m.awayScore);
          const resultLabel = isHome ? m.homeResult : m.awayResult;
          const w = resultLabel === 'win';
          const score = isHome ? `${home}–${away}` : `${away}–${home}`;
          const date = formatFixtureDate(m.fixtureDate);
          html += `
            <div class="tl-row">
              <span class="tl-date">${date}</span>
              <span class="tl-up-opp"><span class="tl-vs">vs </span>${opponent}</span>
              <span class="${w ? 'badge-w' : 'badge-l'}">${w ? 'W' : 'L'} ${score}</span>
            </div>`;
        }
      }

      if (upcoming.length > 0) {
        html += `<div class="tl-section-label">Upcoming Fixtures</div>`;
        upcoming.forEach((m: Match, i: number) => {
          const isHome = parseHomeAway(m) === 'Home';
          const opponent = esc(isHome ? m.awayTeam : m.homeTeam);
          const venue = esc(m.venue ?? '');
          const date = formatFixtureDate(m.fixtureDate);
          const time = formatFixtureTime(m.fixtureDate);
          const venueStr = venue ? `📍 ${venue}${time ? ` · ${time}` : ''}` : (time ?? '');
          const ha = isHome ? 'Home' : 'Away';
          const isNext = i === 0;
          html += `
            <div class="tl-row-up${isNext ? ' tl-row-up--next' : ''}">
              <span class="tl-date">${date}</span>
              <div class="tl-up-meta">
                <span class="tl-up-opp"><span class="tl-vs">vs </span>${opponent}</span>
                ${venueStr ? `<span class="tl-up-venue">${venueStr}</span>` : ''}
              </div>
              <div class="tl-right">
                ${isNext ? '<span class="next-pill">Next</span>' : ''}
                <span class="home-away">${ha}</span>
              </div>
            </div>`;
        });
      }

      html += `
        <div class="tl-footer">
          <span class="tl-updated">${updated ? `Updated ${esc(updated)}` : ''}</span>
          <a href="${esc(vzUrl)}" target="_blank" rel="noopener noreferrer" class="team-fixture-section__volleyzone">Full schedule on Volleyzone →</a>
        </div>`;

      target.innerHTML = html;
    }

    document.querySelectorAll<HTMLElement>('.team-fixture-section').forEach(renderFixtures);
  </script>
</BaseLayout>

<script>
  const pills    = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const rows     = document.querySelectorAll<HTMLElement>('.team-fixture-section');
  const headers  = document.querySelectorAll<HTMLElement>('[data-section]');
  const status   = document.getElementById('filter-status')!

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter!;

      pills.forEach(p => {
        p.classList.remove('filter-pill--active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('filter-pill--active');
      pill.setAttribute('aria-pressed', 'true');

      rows.forEach(row => {
        const show = filter === 'all'
          || filter === row.dataset.gender
          || filter === row.dataset.league;
        row.hidden = !show;
      });

      headers.forEach(header => {
        const gender = header.dataset.section!;
        const anyVisible = Array.from(rows).some(
          r => r.dataset.gender === gender && !r.hidden
        );
        header.hidden = !anyVisible;
      });

      const visibleCount = Array.from(rows).filter(r => !r.hidden).length;
      status.textContent = `Showing ${visibleCount} team${visibleCount !== 1 ? 's' : ''}`;
    });
  });
</script>

<style>
  /* ── Sessions box ── */
  /* S31: no boxed background — the Open Sessions block aligns with the rest of
     the page hierarchy; the eyebrow heading + cards carry the section on their own. */
  .sessions-box {
    margin-bottom: 36px;
  }

  /* Section headers — promote the page's three parts (Open Sessions, Junior
     Sessions, Fixtures & Results) above the small team-group eyebrows. */
  .section-head { margin-bottom: 20px; }
  .section-head__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-black);
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
  }
  .section-head__title em { color: var(--color-accent-text); font-style: normal; }
  .section-head__sub {
    margin-top: 6px;
    max-width: 60ch;
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
  }

  /* Full-width rule that splits the attend-able sessions from the competitive
     fixtures half of the page. */
  .section-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 16px 0 36px;
  }

  /* Caution tone — shown only when the live sheet couldn't load, so the times
     on display may be stale. Amber sits outside the brand palette but reads as
     "unconfirmed" without the alarm of the red loss-badges; values are local +
     AA-checked for both themes (text #875400 on the light tint, #f0c14b on
     navy). */
  .sessions-box__notice {
    font-size: var(--text-note);
    color: #875400;
    background: rgba(217,151,30,0.10);
    border: 1px solid rgba(217,151,30,0.40);
    border-radius: 6px;
    padding: 10px 14px;
    margin-bottom: 20px;
  }

  .sessions-box__notice a {
    color: inherit;
    font-weight: var(--weight-bold);
    text-decoration: underline;
  }

  :global(html[data-theme="dark"]) .sessions-box__notice {
    color: #f0c14b;
    background: rgba(217,151,30,0.14);
    border-color: rgba(217,151,30,0.45);
  }

  /* Columns track the tile count (sessions + venue). Shrinking, even counts
     fold to a balanced 2-up grid and odd counts collapse straight to a single
     column — so we never land on an orphaned row (no 3+1 / 2+1). */
  .session-cards {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, 1fr);   /* fallback */
  }

  .session-cards--2 { grid-template-columns: repeat(2, 1fr); }
  .session-cards--3 { grid-template-columns: repeat(3, 1fr); }
  .session-cards--4 { grid-template-columns: repeat(4, 1fr); }
  .session-cards--5 { grid-template-columns: repeat(5, 1fr); }

  @media (max-width: 900px) {
    .session-cards--5 { grid-template-columns: 1fr; }       /* 5: no clean fold → stack */
  }

  @media (max-width: 820px) {
    .session-cards--4 { grid-template-columns: repeat(2, 1fr); }   /* 4 → 2×2 */
  }

  @media (max-width: 620px) {
    .session-cards--3 { grid-template-columns: 1fr; }       /* 3 → stack (avoids 2+1) */
  }

  @media (max-width: 420px) {
    .session-cards--2,
    .session-cards--4 { grid-template-columns: 1fr; }       /* final fold to single column */
  }

  /* Junior cards — mirror the adult 4-tile grid's column structure and
     breakpoints so a junior tile is exactly the same width as an open-session
     tile. The juniors row carries its own venue tile (same venue), so the
     session card stretches to match it — no hardcoded height needed. */
  .junior-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  @media (max-width: 820px) {
    .junior-cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 420px) {
    .junior-cards { grid-template-columns: 1fr; }
  }

  /* Session cards — community tone: #54a4f7 bg (via .section--community), navy text */
  .session-card {
    border: 1px solid rgba(17,35,75,0.18);
    border-radius: 10px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* S32: photo-backed schedule cards — darkened so they read distinct from the
     blue filter pills below; text goes white over the overlay. */
  .session-card--photo {
    position: relative;
    overflow: hidden;
    border-color: rgba(5,18,43,0.4);
    background: var(--lh-navy-deep);
  }
  .session-card__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .session-card--photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(5,18,43,0.72), rgba(17,35,75,0.84));
  }
  .session-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .session-card__day { font-size: var(--text-body-sm); font-weight: var(--weight-black); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--lh-navy); }
  .session-card__time { font-size: var(--text-lg); font-weight: var(--weight-black); letter-spacing: var(--tracking-display); color: var(--lh-navy); }
  .session-card__level { font-size: var(--text-eyebrow); font-weight: var(--weight-bold); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--lh-navy); }
  .session-card__venue { font-size: var(--text-eyebrow); color: var(--lh-navy); line-height: var(--leading-normal); margin-top: 4px; }

  /* White text on the darkened photo cards (overrides the navy defaults above). */
  .session-card--photo .session-card__day,
  .session-card--photo .session-card__time,
  .session-card--photo .session-card__level,
  .session-card--photo .session-card__venue { color: var(--lh-white); }

  .session-card--venue {
    border-color: rgba(17,35,75,0.18);
    justify-content: center;
  }

  .session-card__venue-label { font-size: var(--text-eyebrow); color: var(--lh-navy); letter-spacing: var(--tracking-wide); text-transform: uppercase; margin-bottom: 4px; }
  .session-card--venue strong { font-size: var(--text-body-sm); font-weight: var(--weight-bold); color: var(--lh-navy); }
  .session-card--venue span { font-size: var(--text-note); color: var(--lh-navy); }
  .session-card__map-link { color: var(--lh-navy); font-size: var(--text-eyebrow); font-weight: var(--weight-bold); text-decoration: none; margin-top: 8px; }
  .session-card__transport { font-size: var(--text-eyebrow); color: var(--lh-navy); margin-top: 4px; line-height: var(--leading-normal); }

  /* ── Team fixture sections ──*/
  .team-fixture-section {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .team-fixture-section__header {
    background: var(--color-bg-alt);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
    gap: 16px;
  }

  .team-fixture-section__name {
