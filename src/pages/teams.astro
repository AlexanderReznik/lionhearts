---
// src/pages/teams.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamCard from '../components/TeamCard.astro';
import { teams } from '../data/teams';

// All 9 teams, women's first then men's (per club convention).
const sortedTeams = [
  ...teams.filter(t => t.gender === "Women's"),
  ...teams.filter(t => t.gender === "Men's"),
];
---

<BaseLayout
  title="Our Teams"
  description="9 teams competing across the NVL Super League and LVA — Women's: Vinarius, Cats, Fury, Beats. Men's: Alpha, Predators, Pride, Roar, Leo. East London's most competitive volleyball club."
>
  <div class="page-hero">
    <p class="page-hero__eyebrow">9 Teams · NVL & LVA</p>
    <h1 class="page-hero__title">Meet Our<br /><em>Teams</em></h1>
    <p class="page-hero__sub">
      Two NVL teams, seven LVA teams — 9 competitive squads, one club identity.
    </p>
  </div>

  <div class="page-content">

    <p class="sr-only" aria-live="polite" id="teams-filter-status"></p>

    <div class="filter-pills" role="group" aria-label="Filter teams">
      {([
        { label: 'All Teams', filter: 'all' },
        { label: "Women's",   filter: 'womens' },
        { label: "Men's",     filter: 'mens' },
        { label: 'NVL',       filter: 'nvl' },
        { label: 'LVA',       filter: 'lva' },
      ] as const).map(({ label, filter }, i) => (
        <button
          type="button"
          data-teams-filter={filter}
          aria-pressed={i === 0 ? "true" : "false"}
          class:list={['filter-pill', { 'filter-pill--active': i === 0 }]}
        >
          {label}
        </button>
      ))}
    </div>

    <div class="teams-grid">
      {sortedTeams.map(team => <TeamCard team={team} />)}
    </div>

    <!-- TODO before launch: confirm team divisions with club; provide real team photos -->

  </div>
</BaseLayout>

<script>
  const pills  = document.querySelectorAll<HTMLButtonElement>('[data-teams-filter]');
  const cards  = document.querySelectorAll<HTMLElement>('.team-card');
  const status = document.getElementById('teams-filter-status')!;

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.teamsFilter!;

      pills.forEach(p => {
        p.classList.remove('filter-pill--active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('filter-pill--active');
      pill.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const show = filter === 'all'
          || filter === card.dataset.gender
          || filter === card.dataset.league;
        card.hidden = !show;
      });

      const visibleCount = Array.from(cards).filter(c => !c.hidden).length;
      status.textContent = `Showing ${visibleCount} team${visibleCount !== 1 ? 's' : ''}`;
    });
  });
</script>

<style>
  /* ── Filter pills (mirrors /events) ── */
  .filter-pills {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .filter-pill {
    padding: 7px 16px;
    border-radius: 20px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.6);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }

  .filter-pill:hover:not(.filter-pill--active) {
    border-color: rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.9);
  }

  .filter-pill:focus-visible {
    outline: 2px solid var(--color-accent-to);
    outline-offset: 3px;
  }

  .filter-pill--active {
    background: linear-gradient(90deg, var(--color-accent-from), var(--color-accent-to));
    border-color: transparent;
    color: #fff;
  }

  /* ── 3×3 teams grid ── */
  .teams-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .teams-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .teams-grid { grid-template-columns: 1fr; }
  }
</style>
