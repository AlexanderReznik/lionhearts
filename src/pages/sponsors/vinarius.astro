---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vinarius London · London Lionhearts VBC"
  description="Vinarius London — East London's independent wine merchant and title sponsor of London Lionhearts VBC. Small-production wines, tastings, and supper clubs in Shoreditch."
>

  <!-- ── HERO ── -->
  <section class="vin-hero">
    <div class="vin-hero__bg" aria-hidden="true"></div>
    <div class="vin-hero__stripe" aria-hidden="true"></div>
    <div class="vin-hero__content">
      <span class="vin-hero__badge">Title Sponsor · London Lionhearts VBC</span>
      <h1 class="vin-hero__name">Vinarius</h1>
      <p class="vin-hero__latin"><em>vinarius, n.</em> — the Latin word for vintner</p>
      <p class="vin-hero__sub">East London's wine. East London's sport.</p>
      <a
        href="https://vinarius.london"
        class="vin-hero__cta"
        target="_blank"
        rel="noopener noreferrer"
      >Visit Vinarius London ↗</a>
    </div>
  </section>

  <!-- ── MANIFESTO ── -->
  <section class="vin-manifesto">
    <p class="vin-manifesto__num" aria-hidden="true">01</p>
    <div class="vin-manifesto__inner">
      <h2 class="vin-manifesto__headline">Two passions.<br />One postcode.</h2>
      <p class="vin-manifesto__body">
        Vinarius and Lionhearts share more than a postcode. Both were built on the same belief:
        that the best communities gather around the things they love most.
        For us, it's volleyball. For them, it's wine.
        Together, we celebrate East London at its very best.
      </p>
    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section class="vin-about">
    <div class="vin-about__inner">
      <div class="vin-about__intro">
        <p class="vin-about__eyebrow">About the Partner</p>
        <h2 class="vin-about__headline">An Independent<br />Wine Merchant</h2>
        <p class="vin-about__body">
          Named from the Latin word for vintner, Vinarius is East London's hub for wine lovers.
          Founded by Marco, Eugenio, and Philippe — three people united by a common passion for
          food and wine — they curate small-production bottles from over 15 countries, and host
          tastings, supper clubs, and bespoke wine experiences from the heart of Shoreditch.
        </p>
        <a
          href="https://vinarius.london"
          class="vin-about__link"
          target="_blank"
          rel="noopener noreferrer"
        >vinarius.london ↗</a>
      </div>

      <div class="vin-about__facts">
        <div class="vin-fact">
          <strong class="vin-fact__num">15+</strong>
          <span class="vin-fact__label">Countries</span>
        </div>
        <div class="vin-fact">
          <strong class="vin-fact__num">3</strong>
          <span class="vin-fact__label">Founders</span>
        </div>
        <div class="vin-fact">
          <strong class="vin-fact__num">∞</strong>
          <span class="vin-fact__label">Small-production<br />winemakers</span>
        </div>
        <div class="vin-fact">
          <strong class="vin-fact__num">E1</strong>
          <span class="vin-fact__label">Shoreditch,<br />East London</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE BRIDGE ── -->
  <section class="vin-bridge" aria-label="Partnership in numbers">
    <div class="vin-bridge__col vin-bridge__col--sport">
      <p class="vin-bridge__eyebrow">On the Court</p>
      <h3 class="vin-bridge__label">London<br />Lionhearts</h3>
      <div class="vin-bridge__stats">
        <div class="vin-bridge__stat">
          <strong>200+</strong>
          <span>Members</span>
        </div>
        <div class="vin-bridge__stat">
          <strong>9</strong>
          <span>Teams</span>
        </div>
        <div class="vin-bridge__stat">
          <strong>1998</strong>
          <span>Founded</span>
        </div>
      </div>
    </div>

    <div class="vin-bridge__divider" aria-hidden="true">
      <span>×</span>
    </div>

    <div class="vin-bridge__col vin-bridge__col--wine">
      <p class="vin-bridge__eyebrow">At the Cellar</p>
      <h3 class="vin-bridge__label">Vinarius<br />London</h3>
      <div class="vin-bridge__stats">
        <div class="vin-bridge__stat">
          <strong>15+</strong>
          <span>Countries</span>
        </div>
        <div class="vin-bridge__stat">
          <strong>100s</strong>
          <span>Producers</span>
        </div>
        <div class="vin-bridge__stat">
          <strong>E1</strong>
          <span>Shoreditch</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── QUOTE ── -->
  <section class="vin-quote">
    <blockquote class="vin-quote__block">
      <p class="vin-quote__mark" aria-hidden="true">"</p>
      <p class="vin-quote__text">A wine hub for wine lovers in East London.</p>
      <footer class="vin-quote__credit">Vinarius London</footer>
    </blockquote>
  </section>

  <!-- ── VISIT ── -->
  <section class="vin-visit">
    <div class="vin-visit__inner">
      <div class="vin-visit__copy">
        <p class="vin-visit__eyebrow">Discover Our Sponsor</p>
        <h2 class="vin-visit__headline">Find Your<br /><em>Next Bottle</em></h2>
        <p class="vin-visit__body">
          Lionhearts members are warmly welcomed at Vinarius. Explore their exceptional
          selection of small-production wines, join a tasting, or simply stop by for
          a conversation with their passionate team.
        </p>
        <a
          href="https://vinarius.london"
          class="btn btn--white"
          target="_blank"
          rel="noopener noreferrer"
        >Visit Vinarius →</a>
      </div>
      <div class="vin-visit__deco" aria-hidden="true">
        <div class="vin-visit__glass">
          <div class="vin-visit__glass-bowl"></div>
          <div class="vin-visit__glass-stem"></div>
          <div class="vin-visit__glass-base"></div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Wine palette (scoped to this page) ── */
  :root {
    --vin-dark:   #0e0409;
    --vin-mid:    #6b1728;
    --vin-bright: #9b2f3e;
    --vin-gold:   #c9a43e;
    --vin-cream:  rgba(255, 246, 230, 0.85);
  }

  /* ── HERO ── */
  .vin-hero {
    min-height: 92vh;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .vin-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 75% 40%, rgba(107, 23, 40, 0.45), transparent),
      radial-gradient(ellipse 50% 60% at 10% 80%, rgba(0, 40, 160, 0.25), transparent),
      radial-gradient(ellipse 40% 40% at 50% 10%, rgba(155, 47, 62, 0.15), transparent);
  }

  .vin-hero__stripe {
    position: absolute;
    top: 0; bottom: 0;
    left: 55%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(201, 164, 62, 0.3) 40%, rgba(201, 164, 62, 0.1) 70%, transparent);
    transform: skewX(-8deg);
  }

  .vin-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 var(--page-px);
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .vin-hero__badge {
    display: inline-block;
    background: rgba(201, 164, 62, 0.15);
    border: 1px solid rgba(201, 164, 62, 0.35);
    color: var(--vin-gold);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 3px;
    margin-bottom: 28px;
  }

  .vin-hero__name {
    font-size: clamp(4rem, 14vw, 11rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -4px;
    text-transform: uppercase;
    background: linear-gradient(135deg, #ffffff 30%, var(--vin-cream) 60%, rgba(201, 164, 62, 0.8) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 24px;
  }

  .vin-hero__latin {
    font-size: 0.875rem;
    color: rgba(255, 246, 230, 0.6);
    font-style: italic;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .vin-hero__sub {
    font-size: 1rem;
    color: rgba(255, 246, 230, 0.7);
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 40px;
  }

  .vin-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(201, 164, 62, 0.4);
    border-radius: 4px;
    padding: 12px 24px;
    color: var(--vin-gold);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 0.2s, border-color 0.2s;
  }

  .vin-hero__cta:hover {
    background: rgba(201, 164, 62, 0.1);
    border-color: rgba(201, 164, 62, 0.7);
  }

  /* ── MANIFESTO ── */
  .vin-manifesto {
    background: var(--vin-dark);
    padding: 100px var(--page-px);
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(107, 23, 40, 0.4);
    border-bottom: 1px solid rgba(107, 23, 40, 0.4);
  }

  .vin-manifesto__num {
    position: absolute;
    top: -20px;
    left: var(--page-px);
    font-size: clamp(8rem, 20vw, 18rem);
    font-weight: 900;
    color: rgba(107, 23, 40, 0.18);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .vin-manifesto__inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .vin-manifesto__headline {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -2px;
    line-height: 0.95;
    color: #fff;
  }

  .vin-manifesto__body {
    font-size: 1rem;
    color: rgba(255, 246, 230, 0.65);
    line-height: 1.8;
  }

  /* ── ABOUT ── */
  .vin-about {
    padding: 100px var(--page-px);
    background: var(--color-bg);
  }

  .vin-about__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .vin-about__eyebrow {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--vin-gold);
    margin-bottom: 16px;
  }

  .vin-about__headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 24px;
  }

  .vin-about__body {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 28px;
  }

  .vin-about__link {
    color: var(--vin-gold);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid rgba(201, 164, 62, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.15s;
  }

  .vin-about__link:hover { border-color: var(--vin-gold); }

  .vin-about__facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(107, 23, 40, 0.2);
    border: 1px solid rgba(107, 23, 40, 0.35);
    border-radius: 16px;
    overflow: hidden;
  }

  .vin-fact {
    background: var(--color-bg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: background 0.2s;
  }

  .vin-fact:hover { background: rgba(107, 23, 40, 0.08); }

  .vin-fact__num {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    color: #fff;
    letter-spacing: -1px;
  }

  .vin-fact__label {
    font-size: 0.6875rem;
    color: rgba(255, 246, 230, 0.55);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    line-height: 1.5;
  }

  /* ── BRIDGE ── */
  .vin-bridge {
    display: grid;
    grid-template-columns: 1fr 72px 1fr;
    min-height: 380px;
  }

  .vin-bridge__col {
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .vin-bridge__col--sport {
    background: linear-gradient(135deg, #002fa8, #0058d8);
  }

  .vin-bridge__col--wine {
    background: linear-gradient(135deg, #5a1020, #8b1a2e);
  }

  .vin-bridge__divider {
    background: var(--vin-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.15);
    border-top: 1px solid rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .vin-bridge__eyebrow {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 12px;
  }

  .vin-bridge__label {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    line-height: 1;
    color: #fff;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .vin-bridge__stats {
    display: flex;
    gap: 32px;
  }

  .vin-bridge__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .vin-bridge__stat strong {
    font-size: 1.5rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .vin-bridge__stat span {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ── QUOTE ── */
  .vin-quote {
    background: var(--vin-dark);
    padding: 100px var(--page-px);
    border-top: 1px solid rgba(107, 23, 40, 0.4);
    border-bottom: 1px solid rgba(107, 23, 40, 0.4);
  }

  .vin-quote__block {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .vin-quote__mark {
    font-size: 8rem;
    line-height: 0.5;
    color: rgba(107, 23, 40, 0.6);
    font-family: Georgia, serif;
    font-weight: 400;
    margin-bottom: 16px;
  }

  .vin-quote__text {
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 24px;
  }

  .vin-quote__credit {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--vin-gold);
  }

  /* ── VISIT ── */
  .vin-visit {
    background: linear-gradient(135deg, #4a0e1c, #6b1728 50%, #4a0e1c);
    padding: 72px var(--page-px);
    position: relative;
    overflow: hidden;
  }

  .vin-visit__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: center;
  }

  .vin-visit__eyebrow {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(201, 164, 62, 0.8);
    margin-bottom: 16px;
  }

  .vin-visit__headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -1.5px;
    line-height: 0.95;
    color: #fff;
    margin-bottom: 20px;
  }

  .vin-visit__headline em {
    color: var(--vin-gold);
    font-style: normal;
  }

  .vin-visit__body {
    color: rgba(255, 246, 230, 0.65);
    font-size: 0.9375rem;
    line-height: 1.75;
    max-width: 480px;
    margin-bottom: 36px;
  }

  /* CSS wine glass */
  .vin-visit__deco {
    opacity: 0.18;
    flex-shrink: 0;
  }

  .vin-visit__glass {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .vin-visit__glass-bowl {
    width: 120px;
    height: 130px;
    border-radius: 0 0 70px 70px;
    border: 3px solid #fff;
    border-top: none;
    position: relative;
  }

  .vin-visit__glass-bowl::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 50%;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 0 0 60px 60px;
  }

  .vin-visit__glass-stem {
    width: 3px;
    height: 80px;
    background: #fff;
  }

  .vin-visit__glass-base {
    width: 90px;
    height: 3px;
    background: #fff;
    border-radius: 2px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .vin-manifesto__inner { grid-template-columns: 1fr; gap: 32px; }
    .vin-about__inner { grid-template-columns: 1fr; gap: 48px; }
    .vin-visit__inner { grid-template-columns: 1fr; }
    .vin-visit__deco { display: none; }

    .vin-bridge {
      grid-template-columns: 1fr;
      grid-template-rows: auto 48px auto;
    }

    .vin-bridge__divider {
      border: none;
      border-left: 1px solid rgba(255,255,255,0.04);
      border-right: 1px solid rgba(255,255,255,0.04);
    }

    .vin-bridge__col { padding: 40px 28px; }
    .vin-bridge__stats { gap: 20px; }
  }

  @media (max-width: 640px) {
    .vin-manifesto { padding: 64px var(--page-px); }
    .vin-about { padding: 64px var(--page-px); }
    .vin-quote { padding: 64px var(--page-px); }
    .vin-visit { padding: 64px var(--page-px); }
    .vin-about__facts { grid-template-columns: 1fr 1fr; }

    /* Badge: shorten to fit one line */
    .vin-hero__badge { white-space: nowrap; font-size: 0.4375rem; letter-spacing: 1.5px; }

    /* Sub: drop uppercase so two lines read comfortably */
    .vin-hero__sub { text-transform: none; font-size: 0.9375rem; letter-spacing: 0; }

    /* Bridge: switch stats to a tighter grid so 3 stats don't crowd */
    .vin-bridge__stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .vin-bridge__stat strong { font-size: 1.25rem; }

    /* Bridge label smaller on very narrow */
    .vin-bridge__label { font-size: 1.375rem; }
  }
</style>
