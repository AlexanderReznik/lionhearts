---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="oob">
    <div class="oob__inner">
      {/* ── Small court to the side; ball landed out of bounds ── */}
      <svg
        class="oob__scene"
        viewBox="0 0 420 240"
        aria-hidden="true"
        focusable="false"
      >
        {/* top-down court diagram, left — uniform solid lines */}
        <g class="oob__court" fill="none" stroke="currentColor" stroke-width="2.5">
          <rect x="40" y="24" width="140" height="192" />
          <line x1="40" y1="88"  x2="180" y2="88"  />
          <line x1="40" y1="120" x2="180" y2="120" />
          <line x1="40" y1="152" x2="180" y2="152" />
        </g>

        {/* ball, out of bounds to the right */}
        <ellipse class="oob__shadow" cx="300" cy="194" rx="32" ry="7" />
        <g transform="translate(300 152)">
          <g class="oob__ball">
            <image href="/brand/volleyball.svg" x="-42" y="-42" width="84" height="84" />
          </g>
        </g>
      </svg>

      <p class="oob__score" aria-hidden="true">404</p>
      <h1 class="oob__title">Out of Bounds</h1>
      <p class="oob__body">
        That serve sailed long — the page you wanted is off the court.
        Let's get you back in play.
      </p>
      <div class="oob__actions">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href="/events" class="btn btn--ghost">Sessions</a>
        <a href="/join" class="btn btn--ghost">Join Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .oob {
    position: relative;
    min-height: 74vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    overflow: hidden;
  }

  .oob__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    max-width: 460px;
  }

  /* ── Scene: court + landed ball ── */
  .oob__scene {
    width: min(440px, 92vw);
    height: auto;
    display: block;
    margin-bottom: 1rem;
    overflow: visible;
    color: var(--color-text);
  }
  .oob__court { stroke-opacity: 0.4; }

  .oob__shadow { fill: var(--color-text); opacity: 0.16; }

  .oob__ball {
    transform-box: fill-box;
    transform-origin: center bottom;
    filter: drop-shadow(0 6px 10px rgba(5, 18, 43, 0.28));
  }

  /* ── Scoreboard 404 ── */
  .oob__score {
    margin-top: 0.25rem;
    padding: 0.35em 0.7em;
    border-radius: 10px;
    background: var(--color-surface-3);
    border: 1px solid var(--color-border-blue);
    color: var(--color-accent-text);
    font-size: var(--text-display);
    font-weight: 900;
    line-height: 1;
    letter-spacing: var(--tracking-wide);
    text-indent: var(--tracking-wide); /* balance the trailing letter-spacing */
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 8px 24px -16px rgba(17, 35, 75, 0.6);
  }

  .oob__title {
    margin-top: 1rem;
    font-size: var(--text-xl);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    line-height: 1.05;
  }

  .oob__body {
    color: var(--color-text-muted);
    max-width: 360px;
    line-height: 1.65;
    font-size: var(--text-body);
  }

  .oob__actions {
    display: flex;
    gap: 12px;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Landing sequence (motion users only) ── */
  @media (prefers-reduced-motion: no-preference) {
    .oob__ball   { animation: oob-drop 1.05s cubic-bezier(0.3, 0.7, 0.35, 1) 0.1s both; }
    .oob__shadow { animation: oob-shadow 0.5s ease-out 0.5s both; }
    .oob__court  { animation: oob-fade 1s ease-out both; }
    .oob__title  { animation: oob-rise 0.6s ease-out 0.95s both; }
    .oob__body   { animation: oob-rise 0.6s ease-out 1.05s both; }
    .oob__actions { animation: oob-rise 0.6s ease-out 1.15s both; }
  }

  @keyframes oob-drop {
    0%   { transform: translateY(-170px) scale(0.85); opacity: 0; }
    10%  { opacity: 1; }
    52%  { transform: translateY(0) scale(1); }
    66%  { transform: translateY(-32px) scale(1); }
    80%  { transform: translateY(0) scale(1.07, 0.9); }
    90%  { transform: translateY(-8px) scale(1); }
    100% { transform: translateY(0) scale(1); }
  }

  @keyframes oob-shadow {
    from { opacity: 0; }
    to   { opacity: 0.16; }
  }

  @keyframes oob-rise {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes oob-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
