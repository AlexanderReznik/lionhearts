---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import BallMark from '../components/BallMark.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="nf">
    <p class="nf__numeral" aria-hidden="true">404</p>
    <BallMark position="center" color="var(--color-accent)" opacity={0.1} size="560px" />

    <div class="nf__inner">
      <p class="nf__eyebrow">Error 404</p>
      <h1 class="nf__title">Out of<br /><span class="nf__title-accent">bounds.</span></h1>
      <p class="nf__body">
        That page sailed past the line — it doesn't exist, or it's left the court.
        Let's get you back in play.
      </p>
      <div class="nf__actions">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href="/events" class="btn btn--ghost">Sessions</a>
        <a href="/join" class="btn btn--ghost">Join Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem var(--page-px);
    text-align: center;
  }

  /* Giant faint numeral — consistent with the site's section numerals */
  .nf__numeral {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -54%);
    font-size: clamp(16rem, 42vw, 34rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.04);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .nf__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 460px;
  }

  .nf__eyebrow {
    font-family: var(--font-condensed);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .nf__title {
    font-size: clamp(3rem, 9vw, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.88;
  }

  .nf__title-accent { color: var(--color-accent); }

  .nf__body {
    color: var(--color-text-muted);
    max-width: 380px;
    line-height: 1.65;
    font-size: 0.9375rem;
  }

  .nf__actions {
    display: flex;
    gap: 12px;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
